MERGE (v:Violation {id: 'ND168_Art26_C7_g'}) SET v.summary = "Sử dụng xe ô tô kinh doanh vận tải không lắp thiết bị ghi nhận hình ảnh người lái xe theo quy định (đối với loại xe có quy định phải lắp thiết bị ghi nhận hình ảnh người lái xe) hoặc có lắp thiết bị ghi nhận hình ảnh người lái xe nhưng không ghi, không lưu trữ được dữ liệu trên xe trong quá trình xe tham gia giao thông theo quy định hoặc làm sai lệch dữ liệu của thiết bị ghi nhận hình ảnh người lái xe lắp trên xe ô tô.", v.article = 26, v.clause = 7, v.fine_min = 5000000, v.fine_max = 6000000, v.severity = "cao", v.slang = "", v.synonyms = "";
