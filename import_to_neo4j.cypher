MERGE (a:Authority {id: 'ND168_Art52_C9_pa'}) SET a.title = "Bỏ cụm từ “camera”, cụm từ “dây an toàn” và cụm từ “thiết bị giám sát hành trình” tại điểm p khoản 2 Điều 4.", a.limit = null, a.raw_text = "Bỏ cụm từ “camera”, cụm từ “dây an toàn” và cụm từ “thiết bị giám sát hành trình” tại điểm p khoản 2 Điều 4;", a.applicable_articles = [4];
MATCH (a:Authority {id: 'ND168_Art52_C9_pa'}), (v:Violation) WHERE v.article IN a.applicable_articles AND (a.limit = 0 OR v.fine_max <= a.limit) MERGE (a)-[:CAN_SANCTION]->(v);
MERGE (a:Authority {id: 'ND168_Art52_C9_pb'}) SET a.title = "Bỏ cụm từ “điểm a” tại điểm c khoản 1 Điều 4a.", a.limit = null, a.raw_text = "Bỏ cụm từ “điểm a” tại điểm c khoản 1 Điều 4a;", a.applicable_articles = [4];
MATCH (a:Authority {id: 'ND168_Art52_C9_pb'}), (v:Violation) WHERE v.article IN a.applicable_articles AND (a.limit = 0 OR v.fine_max <= a.limit) MERGE (a)-[:CAN_SANCTION]->(v);
MERGE (a:Authority {id: 'ND168_Art52_C9_pc'}) SET a.title = "Bỏ cụm từ “Sử dụng trái phép lòng đường đô thị, hè phố để: Họp chợ; kinh doanh dịch vụ ăn uống; bày, bán hàng hóa; sửa chữa phương tiện, máy móc, thiết bị; rửa xe; đặt, treo biển hiệu, biển quảng cáo;” và cụm từ “, trừ các hành vi vi phạm quy định tại điểm d, điểm đ, điểm e, điểm g khoản 6; khoản 7; điểm a khoản 8 Điều này” tại điểm b khoản 5 Điều 12.", a.limit = null, a.raw_text = "Bỏ cụm từ “Sử dụng trái phép lòng đường đô thị, hè phố để: Họp chợ; kinh doanh dịch vụ ăn uống; bày, bán hàng hóa; sửa chữa phương tiện, máy móc, thiết bị; rửa xe; đặt, treo biển hiệu, biển quảng cáo;” và cụm từ “, trừ các hành vi vi phạm quy định tại điểm d, điểm đ, điểm e, điểm g khoản 6; khoản 7; điểm a khoản 8 Điều này” tại điểm b khoản 5 Điều 12;", a.applicable_articles = [12];
MATCH (a:Authority {id: 'ND168_Art52_C9_pc'}), (v:Violation) WHERE v.article IN a.applicable_articles AND (a.limit = 0 OR v.fine_max <= a.limit) MERGE (a)-[:CAN_SANCTION]->(v);
MERGE (a:Authority {id: 'ND168_Art52_C9_pd'}) SET a.title = "Bỏ cụm từ “Điều 9, Điều 10, Điều 11,” tại điểm đ khoản 3, cụm từ “Điều 32, Điều 34;” tại điểm k khoản 3, cụm từ “điểm a khoản 2 Điều 16; điểm a khoản 6 Điều 23; điểm a khoản 2 Điều 32” tại khoản 3a và cụm từ “Điểm a khoản 1,” tại điểm g khoản 4 Điều 74.", a.limit = null, a.raw_text = "Bỏ cụm từ “Điều 9, Điều 10, Điều 11,” tại điểm đ khoản 3, cụm từ “Điều 32, Điều 34;” tại điểm k khoản 3, cụm từ “điểm a khoản 2 Điều 16; điểm a khoản 6 Điều 23; điểm a khoản 2 Điều 32” tại khoản 3a và cụm từ “Điểm a khoản 1,” tại điểm g khoản 4 Điều 74.", a.applicable_articles = [32, 34, 9, 10, 11, 74, 16, 23];
MATCH (a:Authority {id: 'ND168_Art52_C9_pd'}), (v:Violation) WHERE v.article IN a.applicable_articles AND (a.limit = 0 OR v.fine_max <= a.limit) MERGE (a)-[:CAN_SANCTION]->(v);
MERGE (a:Authority {id: 'ND168_Art53_C1'}) SET a.title = "Quy định về ngày có hiệu lực thi hành chung của Nghị định, với một ngoại lệ cụ thể.", a.limit = null, a.raw_text = "Nghị định này có hiệu lực thi hành từ ngày 01 tháng 01 năm 2025, trừ quy định tại khoản 2 Điều này.", a.applicable_articles = [];
MERGE (a:Authority {id: 'ND168_Art53_C2'}) SET a.title = "Quy định các ngày có hiệu lực thi hành cụ thể cho một số điểm, khoản của các Điều khác và quy định việc áp dụng theo pháp luật bảo vệ môi trường cho kiểm định khí thải.", a.limit = null, a.raw_text = "Quy định tại điểm m khoản 3 Điều 6, điểm e khoản 4 Điều 26, điểm b khoản 1 Điều 27 của Nghị định này có hiệu lực thi hành từ ngày 01 tháng 01 năm 2026; quy định tại điểm b khoản 1 Điều 32 của Nghị định này có hiệu lực thi hành theo quy định của pháp luật bảo vệ môi trường về kiểm định khí thải xe mô tô, xe gắn máy.", a.applicable_articles = [32, 26, 27, 6];
MATCH (a:Authority {id: 'ND168_Art53_C2'}), (v:Violation) WHERE v.article IN a.applicable_articles AND (a.limit = 0 OR v.fine_max <= a.limit) MERGE (a)-[:CAN_SANCTION]->(v);
MERGE (a:Authority {id: 'ND168_Art54_C1'}) SET a.title = "Quy định nguyên tắc áp dụng văn bản pháp luật đối với hành vi vi phạm hành chính về trật tự, an toàn giao thông đường bộ đã xảy ra và kết thúc trước ngày Nghị định có hiệu lực thi hành nhưng sau đó mới bị phát hiện hoặc đang xem xét giải quyết.", a.limit = null, a.raw_text = "Trường hợp hành vi vi phạm hành chính về trật tự, an toàn giao thông trong lĩnh vực giao thông đường bộ xảy ra và kết thúc trước ngày Nghị định này có hiệu lực thi hành sau đó mới bị phát hiện hoặc đang xem xét giải quyết thì áp dụng nghị định đang có hiệu lực tại thời điểm thực hiện hành vi vi phạm để xử phạt.", a.applicable_articles = [];
MERGE (a:Authority {id: 'ND168_Art54_C2'}) SET a.title = "Quy định nguyên tắc áp dụng văn bản pháp luật đối với hành vi vi phạm hành chính đang được thực hiện (chưa kết thúc) tại thời điểm phát hiện.", a.limit = null, a.raw_text = "Trường hợp hành vi vi phạm hành chính đang được thực hiện, thì áp dụng nghị định đang có hiệu lực tại thời điểm phát hiện hành vi vi phạm để xử phạt.", a.applicable_articles = [];
MERGE (a:Authority {id: 'ND168_Art55_C1'}) SET a.title = "Xác định các cơ quan và cá nhân chịu trách nhiệm thi hành Nghị định này, bao gồm Bộ trưởng, Thủ trưởng các cơ quan ngang bộ, Thủ trưởng cơ quan thuộc Chính phủ, Chủ tịch Ủy ban nhân dân các tỉnh, thành phố trực thuộc Trung ương và các cơ quan, đơn vị có liên quan.", a.limit = null, a.raw_text = "Các Bộ trưởng, Thủ trưởng cơ quan ngang bộ, Thủ trưởng cơ quan thuộc Chính phủ, Chủ tịch Ủy ban nhân dân các tỉnh, thành phố trực thuộc Trung ương và các cơ quan, đơn vị có liên quan chịu trách nhiệm thi hành Nghị định này./.", a.applicable_articles = [];