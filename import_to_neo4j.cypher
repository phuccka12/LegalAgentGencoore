MERGE (a:Authority {id: 'ND168_Art48_C1_pc'}) SET a.title = "Áp dụng tạm giữ phương tiện đối với các hành vi vi phạm tại Điều 8, cụ thể là điểm c khoản 6; điểm a khoản 7; điểm b khoản 8; điểm a, điểm b, điểm c, điểm d khoản 9.", a.limit = 0, a.raw_text = "Điểm c khoản 6; điểm a khoản 7; điểm b khoản 8; điểm a, điểm b, điểm c, điểm d khoản 9 Điều 8;", a.applicable_articles = [8];
