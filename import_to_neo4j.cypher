MERGE (a:Authority {id: 'ND168_Art48_C1_pn'}) SET a.title = "Áp dụng tạm giữ phương tiện đối với hành vi vi phạm tại khoản 3 Điều 35.", a.limit = 0, a.raw_text = "Khoản 3 Điều 35;", a.applicable_articles = [35];
MATCH (a:Authority {id: 'ND168_Art48_C1_pn'}), (v:Violation) WHERE v.article IN a.applicable_articles AND (a.limit = 0 OR v.fine_max <= a.limit) MERGE (a)-[:CAN_SANCTION]->(v);
MERGE (a:Authority {id: 'ND168_Art48_C1_po'}) SET a.title = "Áp dụng tạm giữ phương tiện đối với các hành vi vi phạm khác quy định tại Nghị định này thuộc trường hợp thật cần thiết cần phải ngăn chặn ngay hành vi vi phạm hành chính mà nếu không tạm giữ thì sẽ gây hậu quả nghiêm trọng cho xã hội.", a.limit = 0, a.raw_text = "Các hành vi vi phạm khác quy định tại Nghị định này thuộc trường hợp thật cần thiết cần phải ngăn chặn ngay hành vi vi phạm hành chính mà nếu không tạm giữ thì sẽ gây hậu quả nghiêm trọng cho xã hội.", a.applicable_articles = [];
MERGE (a:Authority {id: 'ND168_Art48_C1_pđ'}) SET a.title = "Áp dụng tạm giữ phương tiện đối với các hành vi vi phạm tại Điều 12, cụ thể là khoản 10 (trong trường hợp người vi phạm là người điều khiển phương tiện); điểm a khoản 14 (trong trường hợp người vi phạm là người điều khiển phương tiện).", a.limit = 0, a.raw_text = "Khoản 10 (trong trường hợp người vi phạm là người điều khiển phương tiện); điểm a khoản 14 (trong trường hợp người vi phạm là người điều khiển phương tiện) Điều 12;", a.applicable_articles = [12];
MATCH (a:Authority {id: 'ND168_Art48_C1_pđ'}), (v:Violation) WHERE v.article IN a.applicable_articles AND (a.limit = 0 OR v.fine_max <= a.limit) MERGE (a)-[:CAN_SANCTION]->(v);
MERGE (a:Authority {id: 'ND168_Art48_C2'}) SET a.title = "Quy định về thẩm quyền tạm giữ phương tiện, giấy tờ để đảm bảo thi hành quyết định xử phạt hoặc xác minh tình tiết. Trường hợp quá thời hạn hẹn giải quyết mà người vi phạm vẫn điều khiển phương tiện hoặc đưa phương tiện ra giao thông thì bị xử phạt như hành vi không có giấy tờ.", a.limit = 0, a.raw_text = "Để bảo đảm thi hành quyết định xử phạt vi phạm hành chính hoặc để xác minh tình tiết làm căn cứ ra quyết định xử phạt, người có thẩm quyền xử phạt có thể quyết định tạm giữ phương tiện, giấy tờ có liên quan đến người điều khiển và phương tiện vi phạm một trong các hành vi quy định tại Nghị định này theo quy định tại điểm a, điểm c khoản 1; khoản 2; khoản 6; khoản 7; khoản 8 Điều 125 của Luật Xử lý vi phạm hành chính. Khi bị tạm giữ giấy tờ theo quy định tại khoản 6 Điều 125 của Luật Xử lý vi phạm hành chính, nếu quá thời hạn hẹn đến giải quyết vụ việc vi phạm ghi trong biên bản vi phạm hành chính, người vi phạm chưa thực hiện giải quyết vụ việc vi phạm theo quy định mà vẫn tiếp tục điều khiển phương tiện hoặc đưa phương tiện ra tham gia giao thông thì bị áp dụng xử phạt như hành vi không có giấy tờ.", a.applicable_articles = [125];
MATCH (a:Authority {id: 'ND168_Art48_C2'}), (v:Violation) WHERE v.article IN a.applicable_articles AND (a.limit = 0 OR v.fine_max <= a.limit) MERGE (a)-[:CAN_SANCTION]->(v);
MERGE (a:Authority {id: 'ND168_Art48_C3'}) SET a.title = "Quy định cách xử lý đối với trường hợp người điều khiển phương tiện không xuất trình được một, một số hoặc tất cả các giấy tờ liên quan tại thời điểm kiểm tra, bao gồm giấy phép lái xe, chứng nhận đăng ký xe, giấy chứng nhận kiểm định an toàn kỹ thuật và bảo vệ môi trường.", a.limit = 0, a.raw_text = "Đối với trường hợp tại thời điểm kiểm tra, người điều khiển phương tiện không xuất trình được một, một số hoặc tất cả các giấy tờ (giấy phép lái xe, chứng nhận đăng ký xe (hoặc bản sao chứng nhận đăng ký xe có chứng thực kèm theo bản gốc giấy biên nhận còn hiệu lực của tổ chức tín dụng, chi nhánh ngân hàng nước ngoài trong trường hợp tổ chức tín dụng, chi nhánh ngân hàng nước ngoài giữ bản gốc chứng nhận đăng ký xe), giấy chứng nhận kiểm định an toàn kỹ thuật và bảo vệ môi trường) theo quy định (bản giấy hoặc thông tin của các giấy tờ được tích hợp trong tài khoản định danh điện tử) thì xử lý như sau:", a.applicable_articles = [];
MERGE (a:Authority {id: 'ND168_Art48_C3_pa'}) SET a.title = "Trường hợp không xuất trình được giấy tờ, người có thẩm quyền lập biên bản vi phạm hành chính đối với người điều khiển phương tiện (hành vi không có giấy tờ) và chủ phương tiện (hành vi vi phạm tương ứng tại Điều 32), đồng thời tạm giữ phương tiện.", a.limit = 0, a.raw_text = "Người có thẩm quyền tiến hành lập biên bản vi phạm hành chính đối với người điều khiển phương tiện về hành vi không có giấy tờ (tương ứng với những loại giấy tờ không xuất trình được), đồng thời lập biên bản vi phạm hành chính đối với chủ phương tiện về những hành vi vi phạm tương ứng quy định tại Điều 32 của Nghị định này và tạm giữ phương tiện theo quy định;", a.applicable_articles = [32];
MATCH (a:Authority {id: 'ND168_Art48_C3_pa'}), (v:Violation) WHERE v.article IN a.applicable_articles AND (a.limit = 0 OR v.fine_max <= a.limit) MERGE (a)-[:CAN_SANCTION]->(v);
MERGE (a:Authority {id: 'ND168_Art48_C3_pb'}) SET a.title = "Nếu người điều khiển phương tiện kinh doanh vận tải xuất trình được các giấy tờ theo quy định trong thời hạn hẹn giải quyết vụ việc, người có thẩm quyền ra quyết định xử phạt về hành vi không mang theo giấy tờ đối với người điều khiển phương tiện và không xử phạt đối với chủ phương tiện.", a.limit = 0, a.raw_text = "Trong thời hạn hẹn đến giải quyết vụ việc vi phạm ghi trong biên bản vi phạm hành chính, nếu người điều khiển phương tiện kinh doanh vận tải xuất trình được các giấy tờ hoặc thông tin của các giấy tờ được tích hợp trong tài khoản định danh điện tử theo quy định thì người có thẩm quyền ra quyết định xử phạt về hành vi không mang theo giấy tờ đối với người điều khiển phương tiện và không xử phạt đối với chủ phương tiện;", a.applicable_articles = [];
MERGE (a:Authority {id: 'ND168_Art48_C3_pc'}) SET a.title = "Nếu người vi phạm (trừ trường hợp kinh doanh vận tải) xuất trình được các giấy tờ theo quy định trong thời hạn hẹn giải quyết, người có thẩm quyền không xử phạt hành vi không có giấy tờ, không mang theo giấy tờ và không xử phạt đối với chủ phương tiện.", a.limit = 0, a.raw_text = "Trong thời hạn hẹn đến giải quyết vụ việc vi phạm ghi trong biên bản vi phạm hành chính, nếu người vi phạm (trừ trường hợp quy định tại điểm b khoản này) xuất trình được các giấy tờ hoặc thông tin của các giấy tờ được tích hợp trong tài khoản định danh điện tử theo quy định thì người có thẩm quyền không ra quyết định xử phạt vi phạm hành chính đối với hành vi vi phạm không có giấy tờ, không mang theo giấy tờ và không xử phạt đối với chủ phương tiện;", a.applicable_articles = [];
MERGE (a:Authority {id: 'ND168_Art48_C3_pd'}) SET a.title = "Nếu quá thời hạn hẹn giải quyết vụ việc, người vi phạm mới xuất trình hoặc không xuất trình được giấy tờ, thì phải chấp hành quyết định xử phạt đối với các hành vi vi phạm đã ghi trong biên bản.", a.limit = 0, a.raw_text = "Quá thời hạn hẹn đến giải quyết vụ việc vi phạm ghi trong biên bản vi phạm hành chính, người vi phạm mới xuất trình hoặc không xuất trình được giấy tờ hoặc thông tin của các giấy tờ được tích hợp trong tài khoản định danh điện tử theo quy định thì phải chấp hành quyết định xử phạt vi phạm hành chính theo quy định đối với các hành vi vi phạm đã ghi trong biên bản vi phạm hành chính.", a.applicable_articles = [];
MERGE (a:Authority {id: 'ND168_Art48_C4'}) SET a.title = "Khi phương tiện bị tạm giữ theo khoản 1, 2, 3 Điều này, chủ phương tiện phải chịu mọi chi phí phát sinh cho việc thay thế vận chuyển. Trường hợp chủ/người điều khiển phương tiện không có mặt, không chấp hành hoặc phương tiện không an toàn, người có thẩm quyền được di chuyển phương tiện về nơi tạm giữ và chi phí di chuyển do người vi phạm chi trả.", a.limit = 0, a.raw_text = "Khi phương tiện bị tạm giữ theo quy định tại khoản 1, khoản 2, khoản 3 Điều này, chủ phương tiện phải chịu mọi chi phí (nếu có) cho việc sử dụng phương tiện khác thay thế để vận chuyển người, hàng hóa được chở trên phương tiện bị tạm giữ. Trường hợp khi tạm giữ phương tiện vi phạm hành chính nhưng người điều khiển phương tiện, chủ phương tiện không có mặt tại nơi xảy ra vi phạm hoặc có mặt nhưng không chấp hành yêu cầu của người có thẩm quyền tạm giữ hoặc không đáp ứng yêu cầu, điều kiện theo quy định để điều khiển phương tiện hoặc phương tiện không bảo đảm chất lượng an toàn kỹ thuật và bảo vệ môi trường theo quy định thì người có thẩm quyền tạm giữ thực hiện việc di chuyển phương tiện vi phạm về nơi tạm giữ theo quy định; nếu không đủ điều kiện thực hiện thì người có thẩm quyền tạm giữ được thuê tổ chức, cá nhân thực hiện việc di chuyển phương tiện đó. Người điều khiển phương tiện hoặc chủ phương tiện vi phạm phải trả chi phí cho việc thuê di chuyển phương tiện đó về nơi tạm giữ.", a.applicable_articles = [];
MERGE (a:Authority {id: 'ND168_Art49_C1'}) SET a.title = "Quy định về việc quản lý, lưu trữ dữ liệu điểm, trừ điểm, phục hồi điểm giấy phép lái xe trên môi trường điện tử, trong Cơ sở dữ liệu về xử lý vi phạm hành chính về trật tự, an toàn giao thông đường bộ do Bộ Công an xây dựng, quản lý, vận hành.", a.limit = null, a.raw_text = "Dữ liệu về điểm, trừ điểm, phục hồi điểm giấy phép lái xe được quản lý, lưu trữ trên môi trường điện tử, trong Cơ sở dữ liệu về xử lý vi phạm hành chính về trật tự, an toàn giao thông đường bộ do Bộ Công an xây dựng, quản lý, vận hành.", a.applicable_articles = [];
MERGE (a:Authority {id: 'ND168_Art50_C1_pa'}) SET a.title = "Nguyên tắc thời điểm thực hiện trừ điểm giấy phép lái xe sau khi quyết định xử phạt hành chính có hiệu lực.", a.limit = null, a.raw_text = "Việc trừ điểm giấy phép lái xe được thực hiện ngay sau khi quyết định xử phạt vi phạm hành chính đối với hành vi vi phạm mà theo quy định của Nghị định này bị trừ điểm giấy phép lái xe có hiệu lực thi hành;", a.applicable_articles = [];
MERGE (a:Authority {id: 'ND168_Art50_C1_pb'}) SET a.title = "Nguyên tắc trừ điểm khi cá nhân thực hiện nhiều hành vi vi phạm trong cùng một lần, chỉ trừ điểm hành vi bị trừ nhiều điểm nhất.", a.limit = null, a.raw_text = "Trường hợp cá nhân thực hiện nhiều hành vi vi phạm hành chính hoặc vi phạm hành chính nhiều lần mà bị xử phạt trong cùng một lần, nếu có từ 02 hành vi vi phạm trở lên theo quy định bị trừ điểm giấy phép lái xe thì chỉ áp dụng trừ điểm đối với hành vi vi phạm bị trừ nhiều điểm nhất;", a.applicable_articles = [];
MERGE (a:Authority {id: 'ND168_Art50_C1_pc'}) SET a.title = "Nguyên tắc trừ hết số điểm còn lại trên giấy phép lái xe nếu số điểm bị trừ lớn hơn số điểm còn lại.", a.limit = null, a.raw_text = "Trường hợp số điểm còn lại của giấy phép lái xe ít hơn số điểm bị trừ thì áp dụng trừ hết số điểm còn lại của giấy phép lái xe đó;", a.applicable_articles = [];
MERGE (a:Authority {id: 'ND168_Art50_C1_pd'}) SET a.title = "Nguyên tắc trừ điểm đối với giấy phép lái xe tích hợp (không thời hạn và có thời hạn) dựa trên loại phương tiện vi phạm.", a.limit = null, a.raw_text = "Trường hợp giấy phép lái xe tích hợp giấy phép lái xe không thời hạn (xe mô tô, xe tương tự xe mô tô) và giấy phép lái xe có thời hạn (xe ô tô, xe tương tự xe ô tô, xe chở người bốn bánh có gắn động cơ, xe chở hàng bốn bánh có gắn động cơ) thì người có thẩm quyền xử phạt thực hiện trừ điểm đối với giấy phép lái xe không thời hạn khi người điều khiển xe mô tô, xe tương tự xe mô tô hoặc trừ điểm giấy phép lái xe có thời hạn khi người điều khiển xe ô tô, xe tương tự xe ô tô, xe chở người bốn bánh có gắn động cơ, xe chở hàng bốn bánh có gắn động cơ thực hiện hành vi vi phạm hành chính có quy định bị trừ điểm giấy phép lái xe;", a.applicable_articles = [];
MERGE (a:Authority {id: 'ND168_Art50_C1_pđ'}) SET a.title = "Ngoại lệ không trừ điểm giấy phép lái xe khi đang trong thời hạn bị tước quyền sử dụng.", a.limit = null, a.raw_text = "Không trừ điểm giấy phép lái xe khi giấy phép lái xe đó đang trong thời hạn bị tước quyền sử dụng giấy phép lái xe.", a.applicable_articles = [];
MERGE (a:Authority {id: 'ND168_Art50_C2'}) SET a.title = "Quy định thẩm quyền của người xử phạt hành chính trong việc trừ điểm giấy phép lái xe đối với hành vi vi phạm.", a.limit = null, a.raw_text = "Người có thẩm quyền áp dụng hình thức xử phạt tước quyền sử dụng giấy phép, chứng chỉ hành nghề có thời hạn hoặc đình chỉ hoạt động có thời hạn quy định tại Chương II Phần thứ hai của Luật Xử lý vi phạm hành chính, Mục 1 Chương III của Nghị định này và có thẩm quyền xử phạt vi phạm hành chính đối với hành vi vi phạm có quy định trừ điểm giấy phép lái xe thì có thẩm quyền trừ điểm giấy phép lái xe đối với hành vi vi phạm đó.", a.applicable_articles = [];
MERGE (a:Authority {id: 'ND168_Art50_C3_pa'}) SET a.title = "Trình tự cập nhật dữ liệu trừ điểm giấy phép lái xe và thông báo cho người bị trừ điểm, bao gồm trách nhiệm của các cấp thẩm quyền.", a.limit = null, a.raw_text = "Ngay sau khi quyết định xử phạt vi phạm hành chính có hiệu lực thi hành, dữ liệu trừ điểm giấy phép lái xe của người bị xử phạt sẽ được cập nhật tự động vào Cơ sở dữ liệu về xử lý vi phạm hành chính về trật tự, an toàn giao thông đường bộ, người có thẩm quyền trừ điểm giấy phép lái xe thông báo cho người bị trừ điểm giấy phép lái xe biết việc trừ điểm.\nTrường hợp Chủ tịch Ủy ban nhân dân cấp huyện, Chủ tịch Ủy ban nhân dân cấp tỉnh ra quyết định xử phạt vi phạm hành chính đối với hành vi vi phạm có trừ điểm giấy phép lái xe thì Trưởng Công an cấp huyện hoặc Trưởng phòng Cảnh sát giao thông Công an cấp tỉnh có trách nhiệm cập nhật dữ liệu trừ điểm giấy phép lái xe vào Cơ sở dữ liệu về xử lý vi phạm hành chính về trật tự, an toàn giao thông đường bộ;", a.applicable_articles = [];
MERGE (a:Authority {id: 'ND168_Art50_C3_pb'}) SET a.title = "Quy định về hình thức và phương thức thông báo trừ điểm giấy phép lái xe, bao gồm cả thông báo điện tử và cập nhật trên các hệ thống số hóa.", a.limit = null, a.raw_text = "Việc thông báo trừ điểm giấy phép lái xe thực hiện bằng văn bản theo mẫu quy định của Bộ trưởng Bộ Công an và được giao trực tiếp hoặc gửi qua dịch vụ bưu chính hoặc thực hiện thông báo bằng phương thức điện tử thông qua tài khoản của công dân đăng ký trên Cổng dịch vụ công, Ứng dụng giao thông trên thiết bị di động khi đáp ứng điều kiện về cơ sở hạ tầng, kỹ thuật, thông tin; đồng thời cập nhật thông tin về giấy phép lái xe bị trừ điểm trên Trang thông tin điện tử của Cục Cảnh sát giao thông. Trường hợp giấy phép lái xe được thể hiện dưới hình thức thông điệp dữ liệu thì cơ quan, người có thẩm quyền thực hiện cập nhật trạng thái trừ điểm giấy phép lái xe trong căn cước điện tử, tài khoản định danh điện tử trên ứng dụng định danh quốc gia.", a.applicable_articles = [];
MERGE (a:Authority {id: 'ND168_Art51_C1_pa'}) SET a.title = "Cục trưởng Cục Cảnh sát giao thông có trách nhiệm quản lý, vận hành Cơ sở dữ liệu về xử lý vi phạm hành chính về trật tự, an toàn giao thông đường bộ để thực hiện cập nhật, tự động phục hồi điểm giấy phép lái xe đối với trường hợp quy định tại khoản 2 Điều này.", a.limit = null, a.raw_text = "Cục trưởng Cục Cảnh sát giao thông có trách nhiệm quản lý, vận hành Cơ sở dữ liệu về xử lý vi phạm hành chính về trật tự, an toàn giao thông đường bộ để thực hiện cập nhật, tự động phục hồi điểm giấy phép lái xe đối với trường hợp quy định tại khoản 2 Điều này;", a.applicable_articles = [];
MERGE (a:Authority {id: 'ND168_Art51_C1_pb'}) SET a.title = "Cục trưởng Cục Cảnh sát giao thông, Trưởng phòng Cảnh sát giao thông nơi tổ chức kiểm tra kiến thức pháp luật về trật tự, an toàn giao thông đường bộ có thẩm quyền phục hồi điểm cho giấy phép lái xe đối với trường hợp quy định tại khoản 3 Điều này.", a.limit = null, a.raw_text = "Cục trưởng Cục Cảnh sát giao thông, Trưởng phòng Cảnh sát giao thông nơi tổ chức kiểm tra kiến thức pháp luật về trật tự, an toàn giao thông đường bộ có thẩm quyền phục hồi điểm cho giấy phép lái xe đối với trường hợp quy định tại khoản 3 Điều này.", a.applicable_articles = [];
MERGE (a:Authority {id: 'ND168_Art51_C2_pa'}) SET a.title = "Khi đủ thời hạn 12 tháng kể từ ngày bị trừ điểm giấy phép lái xe gần nhất, dữ liệu điểm sẽ được tự động phục hồi đủ 12 điểm (bao gồm cả giấy phép lái xe đang bị tước quyền sử dụng) và cập nhật tự động trong Cơ sở dữ liệu về xử lý vi phạm hành chính về trật tự, an toàn giao thông đường bộ.", a.limit = null, a.raw_text = "Khi đủ thời hạn 12 tháng, kể từ ngày bị trừ điểm giấy phép lái xe gần nhất, dữ liệu điểm giấy phép lái xe sẽ được tự động phục hồi đủ 12 điểm (gồm cả giấy phép lái xe đang trong thời hạn bị tước quyền sử dụng) và cập nhật tự động trong Cơ sở dữ liệu về xử lý vi phạm hành chính về trật tự, an toàn giao thông đường bộ;", a.applicable_articles = [];
MERGE (a:Authority {id: 'ND168_Art51_C2_pb'}) SET a.title = "Ngay sau khi dữ liệu điểm giấy phép lái xe được phục hồi, Cơ sở dữ liệu sẽ tự động chuyển thông tin thông báo cho người được phục hồi điểm giấy phép lái xe biết việc phục hồi điểm theo quy định tại điểm c khoản này.", a.limit = null, a.raw_text = "Ngay sau khi dữ liệu điểm giấy phép lái xe được phục hồi, Cơ sở dữ liệu về xử lý vi phạm hành chính về trật tự, an toàn giao thông đường bộ sẽ tự động chuyển thông tin thông báo cho người được phục hồi điểm giấy phép lái xe biết việc phục hồi điểm theo quy định tại điểm c khoản này;", a.applicable_articles = [];
MERGE (a:Authority {id: 'ND168_Art51_C2_pc'}) SET a.title = "Việc thông báo phục hồi điểm giấy phép lái xe được thực hiện bằng phương thức điện tử thông qua tài khoản công dân trên Cổng dịch vụ công, Ứng dụng giao thông, và cập nhật trên Trang thông tin điện tử của Cục Cảnh sát giao thông. Trường hợp giấy phép lái xe dưới dạng thông điệp dữ liệu, thực hiện cập nhật trạng thái phục hồi điểm trong căn cước điện tử, tài khoản định danh điện tử trên ứng dụng định danh quốc gia.", a.limit = null, a.raw_text = "Việc thông báo phục hồi điểm giấy phép lái xe thực hiện bằng phương thức điện tử thông qua tài khoản của công dân đăng ký trên Cổng dịch vụ công, Ứng dụng giao thông trên thiết bị di động; đồng thời cập nhật thông tin về giấy phép lái xe được phục hồi điểm trên Trang thông tin điện tử của Cục Cảnh sát giao thông. Trường hợp giấy phép lái xe được thể hiện dưới hình thức thông điệp dữ liệu thì thực hiện cập nhật trạng thái phục hồi điểm giấy phép lái xe trong căn cước điện tử, tài khoản định danh điện tử trên ứng dụng định danh quốc gia.", a.applicable_articles = [];
MERGE (a:Authority {id: 'ND168_Art51_C3_pa'}) SET a.title = "Sau khi người có giấy phép lái xe bị trừ hết điểm tham gia kiểm tra kiến thức pháp luật về trật tự, an toàn giao thông đường bộ và đạt yêu cầu, kết quả kiểm tra được cập nhật vào phần mềm kiểm tra và đồng bộ dữ liệu. Dữ liệu điểm giấy phép lái xe sẽ được phục hồi đủ 12 điểm và cập nhật tự động trong Cơ sở dữ liệu về xử lý vi phạm hành chính về trật tự, an toàn giao thông đường bộ.", a.limit = null, a.raw_text = "Sau khi người có giấy phép lái xe bị trừ hết điểm tham gia kiểm tra nội dung kiến thức pháp luật về trật tự, an toàn giao thông đường bộ và đạt yêu cầu, kết quả kiểm tra được cập nhật vào phần mềm kiểm tra kiến thức pháp luật về trật tự, an toàn giao thông đường bộ và đồng bộ dữ liệu với Cơ sở dữ liệu về xử lý vi phạm hành chính về trật tự, an toàn giao thông đường bộ, dữ liệu điểm giấy phép lái xe sẽ được phục hồi đủ 12 điểm và cập nhật tự động trong Cơ sở dữ liệu về xử lý vi phạm hành chính về trật tự, an toàn giao thông đường bộ;", a.applicable_articles = [];
MERGE (a:Authority {id: 'ND168_Art51_C3_pb'}) SET a.title = "Ngay sau khi dữ liệu điểm giấy phép lái xe được phục hồi đủ 12 điểm, người có thẩm quyền quy định tại điểm b khoản 1 Điều này sẽ thông báo cho người được phục hồi điểm giấy phép lái xe biết việc phục hồi điểm.", a.limit = null, a.raw_text = "Ngay sau khi dữ liệu điểm giấy phép lái xe được phục hồi đủ 12 điểm thì người có thẩm quyền quy định tại điểm b khoản 1 Điều này thông báo cho người được phục hồi điểm giấy phép lái xe biết việc phục hồi điểm;", a.applicable_articles = [];
MERGE (a:Authority {id: 'ND168_Art51_C3_pc'}) SET a.title = "Việc thông báo phục hồi điểm giấy phép lái xe thực hiện bằng văn bản theo mẫu của Bộ trưởng Bộ Công an, giao trực tiếp hoặc gửi qua dịch vụ bưu chính, hoặc bằng phương thức điện tử qua tài khoản công dân trên Cổng dịch vụ công, Ứng dụng giao thông. Đồng thời cập nhật thông tin trên Trang thông tin điện tử của Cục Cảnh sát giao thông. Trường hợp giấy phép lái xe dưới dạng thông điệp dữ liệu, cập nhật trạng thái phục hồi điểm trong căn cước điện tử, tài khoản định danh điện tử trên ứng dụng định danh quốc gia.", a.limit = null, a.raw_text = "Việc thông báo phục hồi điểm giấy phép lái xe thực hiện bằng văn bản theo mẫu quy định của Bộ trưởng Bộ Công an và được giao trực tiếp hoặc gửi qua dịch vụ bưu chính hoặc thực hiện thông báo bằng phương thức điện tử thông qua tài khoản của công dân đăng ký trên Cổng dịch vụ công, Ứng dụng giao thông trên thiết bị di động; đồng thời cập nhật thông tin về giấy phép lái xe được phục hồi điểm trên Trang thông tin điện tử của Cục Cảnh sát giao thông. Trường hợp giấy phép lái xe được thể hiện dưới hình thức thông điệp dữ liệu thì cơ quan, người có thẩm quyền thực hiện cập nhật trạng thái phục hồi điểm giấy phép lái xe trong căn cước điện tử, tài khoản định danh điện tử trên ứng dụng định danh quốc gia.", a.applicable_articles = [];
MERGE (a:Authority {id: 'ND168_Art52_C1'}) SET a.title = "Bổ sung khoản 2a vào sau khoản 2 Điều 1, quy định việc áp dụng hình thức, mức xử phạt, biện pháp khắc phục hậu quả, thẩm quyền lập biên bản, thẩm quyền xử phạt, mức phạt tiền cụ thể đối với hành vi vi phạm hành chính trong lĩnh vực giao thông đường bộ, ngoại trừ việc trừ và phục hồi điểm giấy phép lái xe.", a.limit = null, a.raw_text = "Hình thức, mức xử phạt, biện pháp khắc phục hậu quả đối với từng hành vi vi phạm hành chính; thẩm quyền lập biên bản, thẩm quyền xử phạt, mức phạt tiền cụ thể đối với từng chức danh về trật tự, an toàn giao thông trong lĩnh vực giao thông đường bộ thì áp dụng quy định tại Nghị định quy định xử phạt vi phạm hành chính về trật tự, an toàn giao thông trong lĩnh vực giao thông đường bộ; trừ điểm, phục hồi điểm giấy phép lái xe", a.applicable_articles = [];
MERGE (a:Authority {id: 'ND168_Art52_C2_pa'}) SET a.title = "Sửa đổi, bổ sung điểm d khoản 6 Điều 28, quy định hành vi không thực hiện đúng các nội dung đã đăng ký, niêm yết về giá cước, giá dịch vụ, tiêu chuẩn chất lượng dịch vụ vận tải, dịch vụ hỗ trợ vận tải là hành vi vi phạm.", a.limit = null, a.raw_text = "Không thực hiện đúng các nội dung đã đăng ký, niêm yết về: giá cước; giá dịch vụ; tiêu chuẩn chất lượng dịch vụ vận tải, dịch vụ hỗ trợ vận tải;", a.applicable_articles = [];
MERGE (a:Authority {id: 'ND168_Art52_C2_pb'}) SET a.title = "Sửa đổi, bổ sung điểm i khoản 6 Điều 28, quy định hành vi sử dụng phương tiện kinh doanh vận tải có chất lượng không bảo đảm điều kiện của hình thức kinh doanh đã đăng ký là hành vi vi phạm.", a.limit = null, a.raw_text = "Sử dụng phương tiện kinh doanh vận tải có chất lượng không bảo đảm điều kiện của hình thức kinh doanh đã đăng ký;", a.applicable_articles = [];
MERGE (a:Authority {id: 'ND168_Art52_C3_pa'}) SET a.title = "Sửa đổi, bổ sung điểm a khoản 10 Điều 28, quy định việc tước quyền sử dụng phù hiệu từ 01 đến 03 tháng đối với xe vi phạm các hành vi quy định tại các điểm cụ thể của khoản 4, khoản 6 và khoản 7 Điều 28.", a.limit = null, a.raw_text = "Thực hiện hành vi vi phạm quy định tại điểm a, điểm b, điểm d, điểm đ, điểm h, điểm l, điểm o, điểm p, điểm r, điểm s, điểm t khoản 4; điểm d, điểm i, điểm k, điểm l, điểm n, điểm q khoản 6; điểm e khoản 7 Điều này bị tước quyền sử dụng phù hiệu từ 01 tháng đến 03 tháng (nếu có hoặc đã được cấp) đối với xe vi phạm;", a.applicable_articles = [];
MERGE (a:Authority {id: 'ND168_Art52_C3_pb'}) SET a.title = "Sửa đổi, bổ sung điểm b khoản 10 Điều 28, quy định việc tước quyền sử dụng giấy phép kinh doanh vận tải từ 01 đến 03 tháng đối với hành vi vi phạm quy định tại các điểm cụ thể của khoản 4, khoản 6 và khoản 7 Điều 28.", a.limit = null, a.raw_text = "Thực hiện hành vi vi phạm quy định tại điểm i, điểm k khoản 4; điểm h khoản 6; điểm b khoản 7 Điều này bị tước quyền sử dụng giấy phép kinh doanh vận tải từ 01 tháng đến 03 tháng;", a.applicable_articles = [];
MERGE (a:Authority {id: 'ND168_Art52_C4'}) SET a.title = "Sửa đổi, bổ sung điểm h khoản 11 Điều 28, quy định biện pháp khắc phục hậu quả là buộc lắp đặt đồng hồ tính tiền cước, thiết bị in hóa đơn trên xe theo đúng quy định đối với hành vi vi phạm quy định tại điểm n khoản 6 Điều này.", a.limit = null, a.raw_text = "Thực hiện hành vi vi phạm quy định tại điểm n khoản 6 Điều này buộc lắp đặt đồng hồ tính tiền cước, thiết bị in hóa đơn trên xe theo đúng quy định;", a.applicable_articles = [];
MERGE (a:Authority {id: 'ND168_Art52_C5_pa'}) SET a.title = "Sửa đổi, bổ sung điểm b khoản 2 Điều 74, quy định phạm vi áp dụng các điểm, khoản liên quan đến Điều 12.", a.limit = null, a.raw_text = "Điểm a, điểm b, điểm d, điểm đ khoản 2; điểm b, điểm c, điểm d, điểm e khoản 3; khoản 4; điểm b khoản 5; điểm a, điểm b, điểm c, điểm d, điểm h khoản 6 Điều 12;", a.applicable_articles = [12];
