MERGE (a:Authority {id: 'ND168_Art52_C5_pđ'}) SET a.title = "Sửa đổi, bổ sung điểm o khoản 5 Điều 74, quy định phạm vi áp dụng Điều 31.", a.limit = null, a.raw_text = "Điều 31;", a.applicable_articles = [31];
