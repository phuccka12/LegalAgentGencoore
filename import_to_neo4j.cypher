MERGE (a:Authority {id: 'ND168_Art52_C5_pd'}) SET a.title = "Sửa đổi, bổ sung điểm m khoản 5 Điều 74, quy định phạm vi áp dụng các điểm, khoản liên quan đến Điều 28.", a.limit = null, a.raw_text = "Điểm a, điểm b, điểm c, điểm d, điểm đ, điểm i khoản 2; điểm b, điểm c khoản 3; điểm a, điểm b, điểm c, điểm d, điểm đ, điểm h, điểm i, điểm k, điểm l, điểm m, điểm n, điểm o, điểm p, điểm r, điểm s, điểm t khoản 4; điểm a, điểm b, điểm d, điểm h, điểm i, điểm k, điểm l, điểm n, điểm q khoản 6; điểm a, điểm b, điểm c, điểm d, điểm e, điểm g, điểm k khoản 7; điểm c, điểm d khoản 8 Điều 28;", a.applicable_articles = [28];
