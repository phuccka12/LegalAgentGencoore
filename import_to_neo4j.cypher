MERGE (v:Violation {id: 'ND168_Art1_C1_pa'}) SET v.summary = "Nghị định này quy định về xử phạt vi phạm hành chính, các hình thức, mức xử phạt, biện pháp khắc phục hậu quả, thẩm quyền lập biên bản và xử phạt, cũng như mức phạt tiền cụ thể theo từng chức danh đối với vi phạm trật tự, an toàn giao thông đường bộ.", v.article = 1, v.clause = 1, v.fine_min = null, v.fine_max = null, v.severity = "khong_xac_dinh", v.slang = "", v.synonyms = "";
