MERGE (v:Violation {id: 'ND168_Art1_C1_pb'}) SET v.summary = "Nghị định này quy định về mức trừ điểm giấy phép lái xe đối với từng hành vi vi phạm hành chính, cùng với trình tự, thủ tục, và thẩm quyền liên quan đến việc trừ điểm và phục hồi điểm giấy phép lái xe để quản lý việc chấp hành pháp luật về giao thông đường bộ.", v.article = 1, v.clause = 1, v.fine_min = null, v.fine_max = null, v.severity = "khong_xac_dinh", v.slang = "", v.synonyms = "";
