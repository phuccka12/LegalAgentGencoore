MERGE (v:Violation {id: 'ND168_Art6_C3_đ'}) SET v.summary = "Dừng xe, đỗ xe tại vị trí: nơi đường bộ giao nhau hoặc trong phạm vi 05 mét tính từ mép đường giao nhau; điểm đón, trả khách; trước cổng hoặc trong phạm vi 05 mét hai bên cổng trụ sở cơ quan, tổ chức có bố trí đường cho xe ra, vào; nơi phần đường có bề rộng chỉ đủ cho một làn xe cơ giới; che khuất biển báo hiệu đường bộ, đèn tín hiệu giao thông; nơi mở dải phân cách giữa; cách xe ô tô đang đỗ ngược chiều dưới 20 mét trên đường phố hẹp, dưới 40 mét trên đường có một làn xe cơ giới trên một chiều đường.", v.article = 6, v.clause = 3, v.fine_min = 800000, v.fine_max = 1000000, v.severity = "thap", v.slang = "Đỗ bừa, Đỗ xe chình ình, Chiếm lòng đường, Đỗ ẩu, Đỗ láo", v.synonyms = "Vi phạm quy tắc dừng đỗ đường bộ, Dừng đỗ sai quy định";
