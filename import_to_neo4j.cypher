MERGE (v:Violation {id: 'ND168_Art3_C4_pa'}) SET v.summary = "Quy định trách nhiệm thi hành biện pháp buộc nộp lại giấy phép, chứng chỉ hành nghề bị tẩy xóa/sửa chữa (GPLX, ĐK xe, giấy tờ kiểm định...). Người có thẩm quyền sẽ chuyển cho cơ quan cấp.", v.article = 3, v.clause = 4, v.fine_min = null, v.fine_max = null, v.severity = "khong_xac_dinh", v.slang = "", v.synonyms = "";
