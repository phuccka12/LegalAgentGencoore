MERGE (a:Authority {id: 'ND168_Art48_C1_pd'}) SET a.title = "Áp dụng tạm giữ phương tiện đối với các hành vi vi phạm tại Điều 9, cụ thể là điểm p khoản 1; điểm d khoản 3; điểm b, điểm c, điểm d (trong trường hợp người vi phạm là người dưới 16 tuổi và điều khiển phương tiện) khoản 4; khoản 5.", a.limit = 0, a.raw_text = "Điểm p khoản 1; điểm d khoản 3; điểm b, điểm c, điểm d (trong trường hợp người vi phạm là người dưới 16 tuổi và điều khiển phương tiện) khoản 4; khoản 5 Điều 9;", a.applicable_articles = [9];
