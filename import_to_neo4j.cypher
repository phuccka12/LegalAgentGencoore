MATCH (a:Authority {id: 'ND168_Art48_C1_pk'}), (v:Violation) WHERE v.article IN a.applicable_articles AND (a.limit = 0 OR v.fine_max <= a.limit) MERGE (a)-[:CAN_SANCTION]->(v);
MERGE (a:Authority {id: 'ND168_Art48_C1_pl'}) SET a.title = "Áp dụng tạm giữ phương tiện đối với các hành vi vi phạm tại Điều 32, cụ thể là điểm b, điểm đ, điểm e, điểm h khoản 8; điểm b, điểm đ khoản 9; khoản 10; điểm a khoản 11; điểm a, điểm b, điểm d khoản 12; điểm d khoản 13; điểm i khoản 14; điểm c khoản 16; khoản 17.", a.limit = 0, a.raw_text = "Điểm b, điểm đ, điểm e, điểm h khoản 8; điểm b, điểm đ khoản 9; khoản 10; điểm a khoản 11; điểm a, điểm b, điểm d khoản 12; điểm d khoản 13; điểm i khoản 14; điểm c khoản 16; khoản 17 Điều 32;", a.applicable_articles = [32];
