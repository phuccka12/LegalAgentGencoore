MERGE (a:Authority {id: 'ND168_Art45_C1'}) SET a.title = "Nguyên tắc xác định thẩm quyền xử phạt vi phạm hành chính và áp dụng biện pháp khắc phục hậu quả trong lĩnh vực giao thông đường bộ được thực hiện theo quy định tại Điều 52 của Luật Xử lý vi phạm hành chính.", a.limit = null, a.raw_text = "Nguyên tắc xác định thẩm quyền xử phạt vi phạm hành chính và áp dụng biện pháp khắc phục hậu quả về trật tự, an toàn giao thông trong lĩnh vực giao thông đường bộ thực hiện theo quy định tại Điều 52 của Luật Xử lý vi phạm hành chính.", a.applicable_articles = [52];
MATCH (a:Authority {id: 'ND168_Art45_C1'}), (v:Violation) WHERE v.article IN a.applicable_articles AND (a.limit = 0 OR v.fine_max <= a.limit) MERGE (a)-[:CAN_SANCTION]->(v);
MERGE (a:Authority {id: 'ND168_Art45_C2'}) SET a.title = "Quy định thẩm quyền xử phạt vi phạm hành chính của các chức danh tại Điều 42, 43, 44 đối với cá nhân, đồng thời xác định thẩm quyền xử phạt tổ chức gấp đôi thẩm quyền xử phạt cá nhân trong trường hợp phạt tiền.", a.limit = null, a.raw_text = "Thẩm quyền xử phạt vi phạm hành chính của các chức danh quy định tại Điều 42, Điều 43 và Điều 44 của Nghị định này là thẩm quyền áp dụng đối với một hành vi vi phạm hành chính của cá nhân; trong trường hợp phạt tiền, thẩm quyền xử phạt tổ chức gấp 02 lần thẩm quyền xử phạt cá nhân.", a.applicable_articles = [42, 43, 44];
MATCH (a:Authority {id: 'ND168_Art45_C2'}), (v:Violation) WHERE v.article IN a.applicable_articles AND (a.limit = 0 OR v.fine_max <= a.limit) MERGE (a)-[:CAN_SANCTION]->(v);
MERGE (a:Authority {id: 'ND168_Art45_C3'}) SET a.title = "Hướng dẫn xác định mức tối thiểu và tối đa của khung tiền phạt cho hành vi vi phạm chở quá số người quy định tại khoản 2, 4 Điều 20 và khoản 5, 6 Điều 32, bằng cách nhân mức phạt quy định đối với mỗi người vượt quá với số người thực tế vượt quá.", a.limit = null, a.raw_text = "Trường hợp cá nhân, tổ chức thực hiện hành vi vi phạm quy định tại khoản 2, khoản 4 Điều 20; khoản 5, khoản 6 Điều 32 của Nghị định này, việc xác định mức tối thiểu và mức tối đa của khung tiền phạt đối với hành vi vi phạm được căn cứ vào mức tối thiểu và mức tối đa của khung tiền phạt quy định đối với mỗi người vượt quá quy định nhân với số người thực tế vượt quá quy định được phép chở của phương tiện.", a.applicable_articles = [32, 20];
MATCH (a:Authority {id: 'ND168_Art45_C3'}), (v:Violation) WHERE v.article IN a.applicable_articles AND (a.limit = 0 OR v.fine_max <= a.limit) MERGE (a)-[:CAN_SANCTION]->(v);
MERGE (a:Authority {id: 'ND168_Art46_C1'}) SET a.title = "Quy định về các chức danh có thẩm quyền xử phạt vi phạm hành chính về trật tự, an toàn giao thông đường bộ, tham chiếu các Điều 42, 43, 44 của Nghị định này.", a.limit = null, a.raw_text = "Các chức danh có thẩm quyền xử phạt vi phạm hành chính về trật tự, an toàn giao thông trong lĩnh vực giao thông đường bộ được quy định tại Điều 42, Điều 43 và Điều 44 của Nghị định này.", a.applicable_articles = [42, 43, 44];
MATCH (a:Authority {id: 'ND168_Art46_C1'}), (v:Violation) WHERE v.article IN a.applicable_articles AND (a.limit = 0 OR v.fine_max <= a.limit) MERGE (a)-[:CAN_SANCTION]->(v);
MERGE (a:Authority {id: 'ND168_Art46_C2'}) SET a.title = "Quy định thẩm quyền lập biên bản của công chức thuộc Thanh tra Sở Giao thông vận tải đang thi hành công vụ, nhiệm vụ đối với các hành vi vi phạm xảy ra trong phạm vi địa bàn quản lý của Thanh tra Sở Giao thông vận tải.", a.limit = null, a.raw_text = "Công chức thuộc Thanh tra Sở Giao thông vận tải đang thi hành công vụ, nhiệm vụ có thẩm quyền lập biên bản đối với các hành vi vi phạm xảy ra trong phạm vi địa bàn quản lý của Thanh tra Sở Giao thông vận tải.", a.applicable_articles = [];
MERGE (a:Authority {id: 'ND168_Art47_C1'}) SET a.title = "Quy trình xử phạt khi chủ phương tiện có mặt tại nơi xảy ra vi phạm, bao gồm việc lập biên bản vi phạm hành chính và tiến hành xử phạt theo quy định pháp luật.", a.limit = null, a.raw_text = "Trong trường hợp chủ phương tiện vi phạm có mặt tại nơi xảy ra vi phạm thì người có thẩm quyền căn cứ vào hành vi vi phạm để lập biên bản vi phạm hành chính và tiến hành xử phạt theo quy định của pháp luật.", a.applicable_articles = [];
MERGE (a:Authority {id: 'ND168_Art47_C2'}) SET a.title = "Quy trình xử phạt khi chủ phương tiện không có mặt tại nơi xảy ra vi phạm, yêu cầu lập biên bản đối với chủ phương tiện và người điều khiển phải ký với tư cách người chứng kiến.", a.limit = null, a.raw_text = "Trong trường hợp chủ phương tiện vi phạm không có mặt tại nơi xảy ra vi phạm thì người có thẩm quyền căn cứ vào hành vi vi phạm để lập biên bản vi phạm hành chính đối với chủ phương tiện và tiến hành xử phạt theo quy định của pháp luật, người điều khiển phương tiện phải ký vào biên bản vi phạm hành chính với tư cách là người chứng kiến.", a.applicable_articles = [];
MERGE (a:Authority {id: 'ND168_Art47_C3'}) SET a.title = "Nguyên tắc xử phạt khi có các hành vi vi phạm trùng nhau được quy định tại các điều khác nhau của Chương II Nghị định này, áp dụng khi đối tượng vi phạm là như nhau.", a.limit = null, a.raw_text = "Đối với những hành vi vi phạm mà cùng được quy định tại các điều khác nhau của Chương II của Nghị định này, trong trường hợp đối tượng vi phạm trùng nhau thì xử phạt như sau:", a.applicable_articles = [];
MERGE (a:Authority {id: 'ND168_Art47_C3_pa'}) SET a.title = "Quy tắc xử phạt đối với các vi phạm về biển số, chứng nhận đăng ký xe khi chủ phương tiện trực tiếp điều khiển phương tiện, áp dụng theo Điều 32.", a.limit = null, a.raw_text = "Các hành vi vi phạm quy định về biển số, chứng nhận đăng ký xe, chứng nhận đăng ký xe tạm thời quy định tại Điều 13 (điểm a khoản 4; điểm a khoản 6; điểm a, điểm b khoản 7; điểm a khoản 8), Điều 14 (điểm a, điểm b, điểm c khoản 2; điểm a khoản 3), Điều 16 (điểm a khoản 1; điểm a, điểm c, điểm d, điểm đ khoản 2) và các hành vi vi phạm tương ứng quy định tại Điều 32 (điểm đ, điểm e, điểm h khoản 8; điểm đ khoản 9; điểm a, điểm b khoản 12; điểm d khoản 13), trong trường hợp chủ phương tiện là người trực tiếp điều khiển phương tiện thì bị xử phạt theo quy định tại các điểm, khoản tương ứng của Điều 32 của Nghị định này;", a.applicable_articles = [16, 32, 13, 14];
MATCH (a:Authority {id: 'ND168_Art47_C3_pa'}), (v:Violation) WHERE v.article IN a.applicable_articles AND (a.limit = 0 OR v.fine_max <= a.limit) MERGE (a)-[:CAN_SANCTION]->(v);
MERGE (a:Authority {id: 'ND168_Art47_C3_pb'}) SET a.title = "Quy tắc xử phạt đối với các vi phạm về giấy chứng nhận, tem kiểm định an toàn kỹ thuật và bảo vệ môi trường khi chủ phương tiện trực tiếp điều khiển phương tiện, áp dụng theo Điều 32.", a.limit = null, a.raw_text = "Các hành vi vi phạm quy định về giấy chứng nhận, tem kiểm định an toàn kỹ thuật và bảo vệ môi trường của xe quy định tại Điều 13 (điểm a khoản 5; điểm a, điểm b khoản 6), Điều 16 (điểm đ khoản 1; điểm b, điểm đ khoản 2) và các hành vi vi phạm tương ứng quy định tại Điều 32 (điểm b, điểm đ khoản 9; điểm a khoản 11), trong trường hợp chủ phương tiện là người trực tiếp điều khiển phương tiện thì bị xử phạt theo quy định tại các điểm, khoản tương ứng của Điều 32 của Nghị định này;", a.applicable_articles = [16, 32, 13];
MATCH (a:Authority {id: 'ND168_Art47_C3_pb'}), (v:Violation) WHERE v.article IN a.applicable_articles AND (a.limit = 0 OR v.fine_max <= a.limit) MERGE (a)-[:CAN_SANCTION]->(v);
MERGE (a:Authority {id: 'ND168_Art47_C3_pc'}) SET a.title = "Quy tắc xử phạt đối với các vi phạm về thời gian lái xe, thời gian nghỉ, phù hiệu khi chủ phương tiện trực tiếp điều khiển phương tiện, áp dụng theo Điều 32.", a.limit = null, a.raw_text = "Các hành vi vi phạm quy định về thời gian lái xe, thời gian nghỉ giữa hai lần lái xe liên tục của người lái xe, phù hiệu quy định tại Điều 20 (điểm d khoản 6, khoản 7), Điều 21 (điểm b khoản 5, điểm c khoản 6) và các hành vi vi phạm tương ứng quy định tại Điều 32 (điểm d khoản 9, điểm đ khoản 11), trong trường hợp chủ phương tiện là người trực tiếp điều khiển phương tiện thì bị xử phạt theo quy định tại các điểm, khoản tương ứng của Điều 32 của Nghị định này;", a.applicable_articles = [32, 20, 21];
MATCH (a:Authority {id: 'ND168_Art47_C3_pc'}), (v:Violation) WHERE v.article IN a.applicable_articles AND (a.limit = 0 OR v.fine_max <= a.limit) MERGE (a)-[:CAN_SANCTION]->(v);
MERGE (a:Authority {id: 'ND168_Art47_C3_pd'}) SET a.title = "Quy tắc xử phạt đối với các vi phạm về niên hạn sử dụng của phương tiện khi chủ phương tiện trực tiếp điều khiển phương tiện, áp dụng theo Điều 32 khoản 17 điểm c.", a.limit = null, a.raw_text = "Các hành vi vi phạm quy định về niên hạn sử dụng của phương tiện quy định tại Điều 13 (điểm a khoản 9) và các hành vi vi phạm tương ứng quy định tại Điều 32 (điểm c khoản 17), trong trường hợp chủ phương tiện là người trực tiếp điều khiển phương tiện thì bị xử phạt theo quy định tại điểm c khoản 17 Điều 32 của Nghị định này;", a.applicable_articles = [32, 13];
MATCH (a:Authority {id: 'ND168_Art47_C3_pd'}), (v:Violation) WHERE v.article IN a.applicable_articles AND (a.limit = 0 OR v.fine_max <= a.limit) MERGE (a)-[:CAN_SANCTION]->(v);
MERGE (a:Authority {id: 'ND168_Art47_C3_pe'}) SET a.title = "Quy tắc xử phạt đối với các vi phạm về kích thước thùng xe, khoang chở hành lý, lắp/tháo ghế/giường khi chủ phương tiện trực tiếp điều khiển phương tiện, áp dụng theo Điều 32.", a.limit = null, a.raw_text = "Các hành vi vi phạm quy định về kích thước thùng xe, khoang chở hành lý (hầm xe), lắp thêm hoặc tháo bớt ghế, giường nằm trên xe ô tô quy định tại Điều 13 (điểm d khoản 3, điểm b khoản 4) và các hành vi vi phạm tương ứng quy định tại Điều 32 (điểm d khoản 11, điểm h khoản 14), trong trường hợp chủ phương tiện là người trực tiếp điều khiển phương tiện thì bị xử phạt theo quy định tại các điểm, khoản tương ứng của Điều 32 của Nghị định này;", a.applicable_articles = [32, 13];
MATCH (a:Authority {id: 'ND168_Art47_C3_pe'}), (v:Violation) WHERE v.article IN a.applicable_articles AND (a.limit = 0 OR v.fine_max <= a.limit) MERGE (a)-[:CAN_SANCTION]->(v);
MERGE (a:Authority {id: 'ND168_Art47_C3_pg'}) SET a.title = "Quy tắc xử phạt đối với các vi phạm về lắp/sử dụng thiết bị giám sát hành trình, thiết bị ghi nhận hình ảnh người lái xe khi cá nhân kinh doanh vận tải trực tiếp điều khiển phương tiện, áp dụng theo Điều 26.", a.limit = null, a.raw_text = "Các hành vi vi phạm quy định về lắp, sử dụng thiết bị giám sát hành trình, thiết bị ghi nhận hình ảnh người lái xe trên xe ô tô quy định tại Điều 20 (điểm l khoản 5, điểm đ khoản 6), Điều 21 (điểm b khoản 3, điểm c khoản 5), Điều 27 (điểm c khoản 1, điểm a khoản 3) và các hành vi vi phạm tương ứng quy định tại Điều 26 (điểm c, điểm g khoản 7), trong trường hợp cá nhân kinh doanh vận tải là người trực tiếp điều khiển phương tiện thì bị xử phạt theo quy định tại các điểm, khoản tương ứng của Điều 26 của Nghị định này;", a.applicable_articles = [26, 27, 20, 21];
MATCH (a:Authority {id: 'ND168_Art47_C3_pg'}), (v:Violation) WHERE v.article IN a.applicable_articles AND (a.limit = 0 OR v.fine_max <= a.limit) MERGE (a)-[:CAN_SANCTION]->(v);
MERGE (a:Authority {id: 'ND168_Art47_C3_ph'}) SET a.title = "Quy tắc xử phạt đối với các vi phạm về lắp/sử dụng thiết bị giám sát hành trình, thiết bị ghi nhận hình ảnh người lái xe khi chủ phương tiện trực tiếp điều khiển phương tiện, áp dụng theo Điều 32.", a.limit = null, a.raw_text = "Các hành vi vi phạm quy định về lắp, sử dụng thiết bị giám sát hành trình, thiết bị ghi nhận hình ảnh người lái xe trên xe ô tô quy định tại Điều 29 (khoản 1, khoản 3), Điều 30 (khoản 1, khoản 2) và các hành vi vi phạm tương ứng quy định tại Điều 32 (điểm m, điểm n khoản 7), trong trường hợp chủ phương tiện là người trực tiếp điều khiển phương tiện thì bị xử phạt theo quy định tại các điểm, khoản tương ứng của Điều 32 của Nghị định này;", a.applicable_articles = [32, 29, 30];
MATCH (a:Authority {id: 'ND168_Art47_C3_ph'}), (v:Violation) WHERE v.article IN a.applicable_articles AND (a.limit = 0 OR v.fine_max <= a.limit) MERGE (a)-[:CAN_SANCTION]->(v);
MERGE (a:Authority {id: 'ND168_Art47_C3_pi'}) SET a.title = "Quy tắc xử phạt đối với các vi phạm về dây đai an toàn, hướng dẫn an toàn, thoát hiểm khi cá nhân kinh doanh vận tải trực tiếp điều khiển phương tiện, áp dụng theo Điều 26.", a.limit = null, a.raw_text = "Các hành vi vi phạm quy định về dây đai an toàn, hướng dẫn cho hành khách về an toàn giao thông, thoát hiểm khi xảy ra sự cố trên xe quy định tại Điều 20 (điểm h, điểm i khoản 3) và các hành vi vi phạm tương ứng quy định tại Điều 26 (điểm c khoản 2, điểm đ khoản 4) trong trường hợp cá nhân kinh doanh vận tải là người trực tiếp điều khiển phương tiện thì bị xử phạt theo quy định tại các điểm, khoản tương ứng của Điều 26 của Nghị định này;", a.applicable_articles = [26, 20];
MATCH (a:Authority {id: 'ND168_Art47_C3_pi'}), (v:Violation) WHERE v.article IN a.applicable_articles AND (a.limit = 0 OR v.fine_max <= a.limit) MERGE (a)-[:CAN_SANCTION]->(v);
MERGE (a:Authority {id: 'ND168_Art47_C3_pk'}) SET a.title = "Quy tắc xử phạt đối với các vi phạm về đón, trả khách; nhận, trả hàng khi cá nhân kinh doanh vận tải trực tiếp điều khiển phương tiện, áp dụng theo Điều 26 khoản 8 điểm c.", a.limit = null, a.raw_text = "Các hành vi vi phạm quy định về đón, trả khách; nhận, trả hàng quy định tại Điều 20 (khoản 8), Điều 21 (khoản 9) và các hành vi vi phạm tương ứng quy định tại Điều 26 (điểm c khoản 8), trong trường hợp cá nhân kinh doanh vận tải là người trực tiếp điều khiển phương tiện thì bị xử phạt theo quy định tại điểm c khoản 8 Điều 26 của Nghị định này;", a.applicable_articles = [26, 20, 21];
MATCH (a:Authority {id: 'ND168_Art47_C3_pk'}), (v:Violation) WHERE v.article IN a.applicable_articles AND (a.limit = 0 OR v.fine_max <= a.limit) MERGE (a)-[:CAN_SANCTION]->(v);
MERGE (a:Authority {id: 'ND168_Art47_C3_pl'}) SET a.title = "Quy tắc xử phạt đối với các vi phạm về dụng cụ, thiết bị cứu hộ đường bộ khi chủ phương tiện trực tiếp điều khiển phương tiện, áp dụng theo Điều 32 khoản 7 điểm o.", a.limit = null, a.raw_text = "Các hành vi vi phạm quy định về dụng cụ, thiết bị chuyên dùng để cứu hộ, hỗ trợ cứu hộ giao thông đường bộ quy định tại Điều 29 (khoản 2) và hành vi vi phạm tương ứng quy định tại Điều 32 (điểm o khoản 7), trong trường hợp chủ phương tiện là người trực tiếp điều khiển phương tiện thì bị xử phạt theo quy định tại điểm o khoản 7 Điều 32 của Nghị định này;", a.applicable_articles = [32, 29];
MATCH (a:Authority {id: 'ND168_Art47_C3_pl'}), (v:Violation) WHERE v.article IN a.applicable_articles AND (a.limit = 0 OR v.fine_max <= a.limit) MERGE (a)-[:CAN_SANCTION]->(v);
MERGE (a:Authority {id: 'ND168_Art47_C3_pm'}) SET a.title = "Quy tắc xử phạt đối với các vi phạm về thiết bị ghi nhận hình ảnh trẻ em, thiết bị cảnh báo chống bỏ quên trẻ em khi cá nhân kinh doanh vận tải trực tiếp điều khiển phương tiện, áp dụng theo Điều 26 khoản 6 điểm b.", a.limit = null, a.raw_text = "Các hành vi vi phạm quy định về thiết bị ghi nhận hình ảnh trẻ em mầm non, học sinh và thiết bị có chức năng cảnh báo, chống bỏ quên trẻ em trên xe quy định tại Điều 27 (điểm b khoản 3) và hành vi vi phạm tương ứng quy định tại Điều 26 (điểm b khoản 6), trong trường hợp cá nhân kinh doanh vận tải là người trực tiếp điều khiển phương tiện thì bị xử phạt theo quy định tại điểm b khoản 6 Điều 26 của Nghị định này;", a.applicable_articles = [26, 27];
MATCH (a:Authority {id: 'ND168_Art47_C3_pm'}), (v:Violation) WHERE v.article IN a.applicable_articles AND (a.limit = 0 OR v.fine_max <= a.limit) MERGE (a)-[:CAN_SANCTION]->(v);
MERGE (a:Authority {id: 'ND168_Art47_C3_pn'}) SET a.title = "Quy tắc xử phạt đối với các vi phạm về màu sơn, biển báo nhận biết xe chở trẻ em khi cá nhân kinh doanh vận tải trực tiếp điều khiển phương tiện, áp dụng theo Điều 26.", a.limit = null, a.raw_text = "Các hành vi vi phạm quy định về màu sơn, biển báo dấu hiệu nhận biết của xe chở trẻ em mầm non, học sinh quy định tại Điều 27 (điểm c, điểm d khoản 3) và hành vi vi phạm tương ứng quy định tại Điều 26 (điểm c, điểm d khoản 6), trong trường hợp cá nhân kinh doanh vận tải là người trực tiếp điều khiển phương tiện thì bị xử phạt theo quy định tại các điểm, khoản tương ứng của Điều 26 của Nghị định này;", a.applicable_articles = [26, 27];
MATCH (a:Authority {id: 'ND168_Art47_C3_pn'}), (v:Violation) WHERE v.article IN a.applicable_articles AND (a.limit = 0 OR v.fine_max <= a.limit) MERGE (a)-[:CAN_SANCTION]->(v);
MERGE (a:Authority {id: 'ND168_Art47_C3_po'}) SET a.title = "Quy tắc xử phạt đối với các vi phạm về chở hàng siêu trường, siêu trọng, quá khổ, quá tải, quá số người khi chủ phương tiện trực tiếp điều khiển phương tiện, áp dụng theo Điều 32.", a.limit = null, a.raw_text = "Các hành vi vi phạm quy định về chở hàng siêu trường, siêu trọng, chở quá khổ, quá tải, quá số người quy định tại Điều 20, Điều 21, Điều 22, Điều 34 và các hành vi vi phạm tương ứng quy định tại Điều 32, trong trường hợp chủ phương tiện là người trực tiếp điều khiển phương tiện thì bị xử phạt theo quy định tại Điều 32 của Nghị định này;", a.applicable_articles = [32, 34, 20, 21, 22];
MATCH (a:Authority {id: 'ND168_Art47_C3_po'}), (v:Violation) WHERE v.article IN a.applicable_articles AND (a.limit = 0 OR v.fine_max <= a.limit) MERGE (a)-[:CAN_SANCTION]->(v);
MERGE (a:Authority {id: 'ND168_Art47_C3_pp'}) SET a.title = "Quy tắc xử phạt đối với các vi phạm về vận chuyển hàng hóa là phương tiện vận tải, máy móc, thiết bị kỹ thuật, hàng dạng trụ khi chủ phương tiện trực tiếp điều khiển phương tiện, áp dụng theo Điều 32 khoản 13 điểm đ.", a.limit = null, a.raw_text = "Các hành vi vi phạm quy định về vận chuyển hàng hóa là phương tiện vận tải, máy móc, thiết bị kỹ thuật, hàng dạng trụ quy định tại Điều 21 (điểm a khoản 10) và hành vi vi phạm tương ứng quy định tại Điều 32 (điểm đ khoản 13), trong trường hợp chủ phương tiện là người trực tiếp điều khiển phương tiện thì bị xử phạt theo quy định tại điểm đ khoản 13 Điều 32 của Nghị định này;", a.applicable_articles = [32, 21];
MATCH (a:Authority {id: 'ND168_Art47_C3_pp'}), (v:Violation) WHERE v.article IN a.applicable_articles AND (a.limit = 0 OR v.fine_max <= a.limit) MERGE (a)-[:CAN_SANCTION]->(v);
MERGE (a:Authority {id: 'ND168_Art47_C3_pq'}) SET a.title = "Quy tắc xử phạt đối với các vi phạm về niêm yết thông tin (hành trình chạy xe) khi cá nhân kinh doanh vận tải trực tiếp điều khiển phương tiện, áp dụng theo Điều 26 khoản 4 điểm g.", a.limit = null, a.raw_text = "Các hành vi vi phạm quy định về niêm yết thông tin (hành trình chạy xe) quy định tại Điều 20 (điểm k khoản 3) và hành vi vi phạm tương ứng quy định tại Điều 26 (điểm g khoản 4), trong trường hợp cá nhân kinh doanh vận tải là người trực tiếp điều khiển phương tiện thì bị xử phạt theo quy định tại điểm g khoản 4 Điều 26 của Nghị định này;", a.applicable_articles = [26, 20];
MATCH (a:Authority {id: 'ND168_Art47_C3_pq'}), (v:Violation) WHERE v.article IN a.applicable_articles AND (a.limit = 0 OR v.fine_max <= a.limit) MERGE (a)-[:CAN_SANCTION]->(v);
MERGE (a:Authority {id: 'ND168_Art47_C3_pr'}) SET a.title = "Quy tắc xử phạt đối với các vi phạm về không thực hiện đúng các nội dung thông tin đã niêm yết (tuyến đường, lịch trình, hành trình vận tải) khi cá nhân kinh doanh vận tải trực tiếp điều khiển phương tiện, áp dụng theo Điều 26 khoản 7 điểm b.", a.limit = null, a.raw_text = "Các hành vi vi phạm quy định về không thực hiện đúng các nội dung thông tin đã niêm yết (tuyến đường, lịch trình, hành trình vận tải) quy định tại Điều 20 (điểm c khoản 3) và các hành vi vi phạm tương ứng quy định tại Điều 26 (điểm b khoản 7), trong trường hợp cá nhân kinh doanh vận tải là người trực tiếp điều khiển phương tiện thì bị xử phạt theo quy định tại điểm b khoản 7 Điều 26 của Nghị định này;", a.applicable_articles = [26, 20];
MATCH (a:Authority {id: 'ND168_Art47_C3_pr'}), (v:Violation) WHERE v.article IN a.applicable_articles AND (a.limit = 0 OR v.fine_max <= a.limit) MERGE (a)-[:CAN_SANCTION]->(v);
MERGE (a:Authority {id: 'ND168_Art47_C3_ps'}) SET a.title = "Quy tắc xử phạt đối với các vi phạm về lệnh vận chuyển, giấy vận tải khi cá nhân kinh doanh vận tải trực tiếp điều khiển phương tiện, áp dụng theo Điều 26 khoản 2 điểm đ.", a.limit = null, a.raw_text = "Các hành vi vi phạm quy định về lệnh vận chuyển, giấy vận tải quy định tại Điều 20 (điểm e khoản 5), Điều 21 (điểm đ khoản 2) và hành vi vi phạm tương ứng quy định tại Điều 26 (điểm đ khoản 2), trong trường hợp cá nhân kinh doanh vận tải là người trực tiếp điều khiển phương tiện thì bị xử phạt theo quy định tại điểm đ khoản 2 Điều 26 của Nghị định này;", a.applicable_articles = [26, 20, 21];
MATCH (a:Authority {id: 'ND168_Art47_C3_ps'}), (v:Violation) WHERE v.article IN a.applicable_articles AND (a.limit = 0 OR v.fine_max <= a.limit) MERGE (a)-[:CAN_SANCTION]->(v);
MERGE (a:Authority {id: 'ND168_Art47_C3_pt'}) SET a.title = "Quy tắc xử phạt đối với các vi phạm về vận chuyển hàng hóa nguy hiểm mà không làm sạch hoặc không bóc (xóa) biểu trưng nguy hiểm khi cá nhân kinh doanh vận tải trực tiếp điều khiển phương tiện, áp dụng theo Điều 26 khoản 2 điểm e.", a.limit = null, a.raw_text = "Các hành vi vi phạm quy định về vận chuyển hàng hóa nguy hiểm mà không làm sạch hoặc không bóc (xóa) biểu trưng nguy hiểm trên phương tiện khi không tiếp tục vận chuyển loại hàng hóa đó quy định tại Điều 23 (khoản 1) và hành vi vi phạm tương ứng quy định tại Điều 26 (điểm e khoản 2), trong trường hợp cá nhân kinh doanh vận tải là người trực tiếp điều khiển phương tiện thì bị xử phạt theo quy định tại điểm e khoản 2 Điều 26 của Nghị định này.", a.applicable_articles = [26, 23];
MATCH (a:Authority {id: 'ND168_Art47_C3_pt'}), (v:Violation) WHERE v.article IN a.applicable_articles AND (a.limit = 0 OR v.fine_max <= a.limit) MERGE (a)-[:CAN_SANCTION]->(v);
MERGE (a:Authority {id: 'ND168_Art47_C3_pđ'}) SET a.title = "Quy tắc xử phạt đối với các vi phạm về niên hạn sử dụng của phương tiện khi cá nhân kinh doanh vận tải trực tiếp điều khiển phương tiện, áp dụng theo Điều 26 khoản 7 điểm i.", a.limit = null, a.raw_text = "Các hành vi vi phạm quy định về niên hạn sử dụng của phương tiện quy định tại Điều 13 (điểm c khoản 5) và các hành vi vi phạm tương ứng quy định tại Điều 26 (điểm i khoản 7), trong trường hợp cá nhân kinh doanh vận tải là người trực tiếp điều khiển phương tiện thì bị xử phạt theo quy định tại điểm i khoản 7 Điều 26 của Nghị định này;", a.applicable_articles = [26, 13];
MATCH (a:Authority {id: 'ND168_Art47_C3_pđ'}), (v:Violation) WHERE v.article IN a.applicable_articles AND (a.limit = 0 OR v.fine_max <= a.limit) MERGE (a)-[:CAN_SANCTION]->(v);
MERGE (a:Authority {id: 'ND168_Art47_C4'}) SET a.title = "Nguyên tắc xử phạt đối với hành vi vi phạm quy định về tải trọng, khổ giới hạn của phương tiện và đường bộ. Nếu vi phạm đồng thời Điều 21 và Điều 34 thì xử phạt từng hành vi. Nếu vi phạm tổng trọng lượng và tải trọng trục xe (Điều 34 khoản 4 điểm a, khoản 5 điểm a) thì xử phạt theo hành vi có mức phạt tiền cao hơn.", a.limit = null, a.raw_text = "Đối với những hành vi vi phạm quy định về tải trọng, khổ giới hạn của phương tiện, của đường bộ quy định tại Điều 21, Điều 34 của Nghị định này, trong trường hợp chủ phương tiện, người điều khiển phương tiện vừa thực hiện hành vi vi phạm quy định tại Điều 21, vừa thực hiện hành vi vi phạm quy định tại Điều 34 của Nghị định này thì bị xử phạt về từng hành vi vi phạm; đối với những hành vi vi phạm được quy định tại điểm a khoản 4, điểm a khoản 5 Điều 34 của Nghị định này, trong trường hợp chủ phương tiện, người điều khiển phương tiện vừa thực hiện hành vi vi phạm quy định về tổng trọng lượng (khối lượng toàn bộ) của xe, vừa thực hiện hành vi vi phạm quy định về tải trọng trục xe thì bị xử phạt theo quy định của hành vi vi phạm có mức phạt tiền cao hơn.", a.applicable_articles = [34, 21];
MATCH (a:Authority {id: 'ND168_Art47_C4'}), (v:Violation) WHERE v.article IN a.applicable_articles AND (a.limit = 0 OR v.fine_max <= a.limit) MERGE (a)-[:CAN_SANCTION]->(v);
MERGE (a:Authority {id: 'ND168_Art47_C5'}) SET a.title = "Các biện pháp khắc phục hậu quả hoặc hình phạt bổ sung buộc chấm dứt hành vi vi phạm đối với các hành vi vi phạm quy định về sử dụng lòng đường, vỉa hè, bảo vệ môi trường, chở người/hàng quá quy định, chằng buộc hàng hóa.", a.limit = null, a.raw_text = "Đối với các hành vi vi phạm quy định về sử dụng lòng đường, vỉa hè vào mục đích khác, bảo vệ môi trường, chở người vượt quá quy định được phép chở của phương tiện, vi phạm quy định về tải trọng, khổ giới hạn của phương tiện, của đường bộ vi phạm về chằng buộc vận chuyển hàng hóa quy định tại Điều 12, Điều 17, Điều 20, Điều 21, Điều 26, Điều 32, Điều 34 của Nghị định này, người điều khiển phương tiện, chủ phương tiện, đơn vị kinh doanh vận tải, dịch vụ hỗ trợ vận tải, cá nhân, tổ chức vi phạm, xếp hàng lên xe ô tô thì buộc chấm dứt hành vi vi phạm theo quy định cụ thể sau đây:", a.applicable_articles = [32, 34, 12, 17, 20, 21, 26];
MATCH (a:Authority {id: 'ND168_Art47_C5'}), (v:Violation) WHERE v.article IN a.applicable_articles AND (a.limit = 0 OR v.fine_max <= a.limit) MERGE (a)-[:CAN_SANCTION]->(v);
MERGE (a:Authority {id: 'ND168_Art47_C5_pa'}) SET a.title = "Biện pháp khắc phục hậu quả đối với các vi phạm tại Điều 12 liên quan đến việc thu dọn vật liệu, chướng ngại vật trên đường bộ.", a.limit = null, a.raw_text = "Thực hiện hành vi vi phạm quy định tại điểm g khoản 2; khoản 7; khoản 9; điểm a khoản 11; điểm b khoản 14 Điều 12 thì buộc thu dọn thóc, lúa, rơm, rạ, nông, lâm, hải sản, máy tuốt lúa trên đường bộ; thu dọn chướng ngại vật, vật cản khác, vật sắc nhọn, chất gây trơn trượt trên đường bộ, hàng hóa, vật tư, hóa chất, chất thải; thu dọn phương tiện, máy móc, thiết bị, biển hiệu, biển quảng cáo theo hướng dẫn của lực lượng chức năng tại nơi phát hiện vi phạm;", a.applicable_articles = [12];
MATCH (a:Authority {id: 'ND168_Art47_C5_pa'}), (v:Violation) WHERE v.article IN a.applicable_articles AND (a.limit = 0 OR v.fine_max <= a.limit) MERGE (a)-[:CAN_SANCTION]->(v);
MERGE (a:Authority {id: 'ND168_Art47_C5_pb'}) SET a.title = "Biện pháp khắc phục hậu quả đối với các vi phạm tại Điều 17 liên quan đến việc thu dọn rác, chất phế thải, vật liệu, hàng hóa.", a.limit = null, a.raw_text = "Thực hiện hành vi vi phạm quy định tại khoản 2, khoản 3, khoản 4 Điều 17 thì buộc thu dọn rác, chất phế thải, vật liệu, hàng hóa theo hướng dẫn của lực lượng chức năng tại nơi phát hiện vi phạm;", a.applicable_articles = [17];
MATCH (a:Authority {id: 'ND168_Art47_C5_pb'}), (v:Violation) WHERE v.article IN a.applicable_articles AND (a.limit = 0 OR v.fine_max <= a.limit) MERGE (a)-[:CAN_SANCTION]->(v);
MERGE (a:Authority {id: 'ND168_Art47_C5_pc'}) SET a.title = "Biện pháp khắc phục hậu quả đối với các vi phạm tại Điều 21 liên quan đến việc hạ phần hàng quá tải, dỡ phần hàng vượt quá kích thước quy định.", a.limit = null, a.raw_text = "Thực hiện hành vi vi phạm quy định tại điểm a, điểm b, điểm d khoản 2; điểm a, điểm d khoản 5; điểm a, điểm b khoản 6; khoản 7; điểm a, điểm b khoản 8 Điều 21 thì buộc hạ phần hàng quá tải, dỡ phần hàng vượt quá kích thước quy định theo hướng dẫn của lực lượng chức năng tại nơi phát hiện vi phạm;", a.applicable_articles = [21];
MATCH (a:Authority {id: 'ND168_Art47_C5_pc'}), (v:Violation) WHERE v.article IN a.applicable_articles AND (a.limit = 0 OR v.fine_max <= a.limit) MERGE (a)-[:CAN_SANCTION]->(v);
MERGE (a:Authority {id: 'ND168_Art47_C5_pd'}) SET a.title = "Biện pháp khắc phục hậu quả đối với các vi phạm tại Điều 26 liên quan đến việc hạ phần hàng xếp vượt quá tải trọng cho phép chở khi phương tiện chưa rời khỏi khu vực xếp hàng.", a.limit = null, a.raw_text = "Thực hiện hành vi vi phạm quy định tại điểm a khoản 1; khoản 3; khoản 5 Điều 26 thì buộc hạ phần hàng xếp vượt quá tải trọng cho phép chở của xe trong trường hợp phương tiện được xếp hàng chưa rời khỏi khu vực xếp hàng;", a.applicable_articles = [26];
MATCH (a:Authority {id: 'ND168_Art47_C5_pd'}), (v:Violation) WHERE v.article IN a.applicable_articles AND (a.limit = 0 OR v.fine_max <= a.limit) MERGE (a)-[:CAN_SANCTION]->(v);
MERGE (a:Authority {id: 'ND168_Art47_C5_pe'}) SET a.title = "Biện pháp khắc phục hậu quả đối với các vi phạm tại Điều 34 liên quan đến việc hạ phần hàng quá tải, dỡ phần hàng quá khổ.", a.limit = null, a.raw_text = "Thực hiện hành vi vi phạm quy định tại khoản 1; khoản 2; điểm a, điểm c, điểm d khoản 3; khoản 4; khoản 5 Điều 34 thì buộc hạ phần hàng quá tải, dỡ phần hàng quá khổ theo hướng dẫn của lực lượng chức năng tại nơi phát hiện vi phạm;", a.applicable_articles = [34];
MATCH (a:Authority {id: 'ND168_Art47_C5_pe'}), (v:Violation) WHERE v.article IN a.applicable_articles AND (a.limit = 0 OR v.fine_max <= a.limit) MERGE (a)-[:CAN_SANCTION]->(v);
MERGE (a:Authority {id: 'ND168_Art47_C5_pg'}) SET a.title = "Biện pháp khắc phục hậu quả đối với các vi phạm tại Điều 20 và Điều 32 liên quan đến việc chở quá số lượng hành khách, buộc bố trí phương tiện khác để chở số hành khách vượt quá quy định.", a.limit = null, a.raw_text = "Thực hiện hành vi vi phạm quy định tại khoản 2, khoản 4 Điều 20; khoản 5, khoản 6, các điểm d, đ khoản 17 Điều 32 thì buộc bố trí phương tiện khác để chở số hành khách vượt quá quy định được phép chở của phương tiện;", a.applicable_articles = [32, 20];
MATCH (a:Authority {id: 'ND168_Art47_C5_pg'}), (v:Violation) WHERE v.article IN a.applicable_articles AND (a.limit = 0 OR v.fine_max <= a.limit) MERGE (a)-[:CAN_SANCTION]->(v);
MERGE (a:Authority {id: 'ND168_Art47_C5_ph'}) SET a.title = "Biện pháp khắc phục hậu quả đối với các vi phạm tại Điều 21 liên quan đến việc chằng buộc hàng hóa, dỡ hàng hóa trên nóc buồng lái, cố định cửa thùng xe, sử dụng cơ cấu khóa hãm công-ten-nơ.", a.limit = null, a.raw_text = "Thực hiện hành vi vi phạm quy định tại khoản 1, điểm đ khoản 8, khoản 10 Điều 21 thì buộc chằng buộc hàng hóa theo quy định; buộc dỡ hàng hóa trên nóc buồng lái; buộc chốt, đóng (cố định) cửa sau, cửa bên thùng xe; buộc sử dụng cơ cấu khóa hãm công-ten-nơ theo quy định.", a.applicable_articles = [21];
MATCH (a:Authority {id: 'ND168_Art47_C5_ph'}), (v:Violation) WHERE v.article IN a.applicable_articles AND (a.limit = 0 OR v.fine_max <= a.limit) MERGE (a)-[:CAN_SANCTION]->(v);
MERGE (a:Authority {id: 'ND168_Art47_C5_pđ'}) SET a.title = "Biện pháp khắc phục hậu quả đối với các vi phạm tại Điều 32 liên quan đến việc hạ phần hàng quá tải, dỡ phần hàng quá khổ.", a.limit = null, a.raw_text = "Thực hiện hành vi vi phạm quy định tại điểm đ, điểm e, điểm g khoản 7; điểm c khoản 9; điểm b, điểm c khoản 11; điểm a, điểm b, điểm c khoản 13; điểm a, điểm b, điểm c, điểm d, điểm đ, điểm e, điểm g khoản 14; khoản 15; điểm a, điểm b khoản 16; điểm g khoản 17 Điều 32 thì buộc hạ phần hàng quá tải, dỡ phần hàng quá khổ theo hướng dẫn của lực lượng chức năng tại nơi phát hiện vi phạm;", a.applicable_articles = [32];
MATCH (a:Authority {id: 'ND168_Art47_C5_pđ'}), (v:Violation) WHERE v.article IN a.applicable_articles AND (a.limit = 0 OR v.fine_max <= a.limit) MERGE (a)-[:CAN_SANCTION]->(v);
MERGE (a:Authority {id: 'ND168_Art47_C6'}) SET a.title = "Định nghĩa các đối tượng được coi là chủ phương tiện để áp dụng xử phạt theo Nghị định này.", a.limit = null, a.raw_text = "Chủ phương tiện bị xử phạt theo quy định tại Nghị định này là một trong các đối tượng sau đây:", a.applicable_articles = [];
MERGE (a:Authority {id: 'ND168_Art47_C6_pa'}) SET a.title = "Cá nhân, tổ chức đứng tên trong chứng nhận đăng ký xe được xem là chủ phương tiện.", a.limit = null, a.raw_text = "Cá nhân, tổ chức đứng tên trong chứng nhận đăng ký xe;", a.applicable_articles = [];
MERGE (a:Authority {id: 'ND168_Art47_C6_pb'}) SET a.title = "Người điều khiển phương tiện là chồng (vợ) của cá nhân đứng tên trong chứng nhận đăng ký xe sẽ bị xử phạt như chủ phương tiện.", a.limit = null, a.raw_text = "Trường hợp người điều khiển phương tiện là chồng (vợ) của cá nhân đứng tên trong chứng nhận đăng ký xe thì người điều khiển phương tiện là đối tượng để áp dụng xử phạt như chủ phương tiện;", a.applicable_articles = [];
MERGE (a:Authority {id: 'ND168_Art47_C6_pc'}) SET a.title = "Cá nhân, tổ chức thuê phương tiện từ tổ chức có chức năng cho thuê tài chính được xem là chủ phương tiện.", a.limit = null, a.raw_text = "Đối với phương tiện được thuê tài chính của tổ chức có chức năng cho thuê tài chính thì cá nhân, tổ chức thuê phương tiện là đối tượng để áp dụng xử phạt như chủ phương tiện;", a.applicable_articles = [];
MERGE (a:Authority {id: 'ND168_Art47_C6_pd'}) SET a.title = "Hợp tác xã đứng tên làm thủ tục đăng ký kinh doanh vận tải cho phương tiện thuộc sở hữu của thành viên được xem là chủ phương tiện.", a.limit = null, a.raw_text = "Đối với phương tiện thuộc sở hữu của thành viên hợp tác xã và được hợp tác xã đứng tên làm thủ tục đăng ký kinh doanh vận tải bằng xe ô tô thì hợp tác xã đó là đối tượng để áp dụng xử phạt như chủ phương tiện;", a.applicable_articles = [];
MERGE (a:Authority {id: 'ND168_Art47_C6_pe'}) SET a.title = "Cá nhân, tổ chức đã mua, được chuyển nhượng, trao đổi, tặng cho, thừa kế phương tiện nhưng chưa làm thủ tục cấp mới/đổi đăng ký xe hoặc biển số xe được xem là chủ phương tiện.", a.limit = null, a.raw_text = "Đối với phương tiện chưa làm thủ tục cấp mới chứng nhận đăng ký xe và biển số xe hoặc chưa làm thủ tục cấp chứng nhận đăng ký xe trong trường hợp thay đổi chủ xe theo quy định thì cá nhân, tổ chức đã mua, được chuyển nhượng, được trao đổi, được tặng cho, được thừa kế là đối tượng để áp dụng xử phạt như chủ phương tiện;", a.applicable_articles = [];
MERGE (a:Authority {id: 'ND168_Art47_C6_pg'}) SET a.title = "Đối với tổ hợp xe (ô tô kéo rơ moóc/sơ mi rơ moóc), nếu chủ xe ô tô không đồng thời là chủ rơ moóc/sơ mi rơ moóc, thì chủ xe ô tô sẽ bị xử phạt như chủ phương tiện đối với các vi phạm liên quan đến rơ moóc/sơ mi rơ moóc.", a.limit = null, a.raw_text = "Đối với tổ hợp xe (gồm xe ô tô kéo theo rơ moóc hoặc sơ mi rơ moóc tham gia giao thông trên đường bộ), trong trường hợp chủ của xe ô tô không đồng thời là chủ của rơ moóc, sơ mi rơ moóc thì chủ của xe ô tô (cá nhân, tổ chức quy định tại điểm a khoản này hoặc cá nhân, tổ chức quy định tại điểm b, điểm c, điểm d, điểm đ, điểm e khoản này) là đối tượng để áp dụng xử phạt như chủ phương tiện đối với các vi phạm liên quan đến rơ moóc, sơ mi rơ moóc được kéo theo tham gia giao thông trên đường bộ.", a.applicable_articles = [];
MERGE (a:Authority {id: 'ND168_Art47_C6_pđ'}) SET a.title = "Tổ chức, cá nhân có quyền sử dụng hợp pháp phương tiện và trực tiếp đứng tên làm thủ tục đăng ký kinh doanh vận tải, cứu hộ, cứu thương được xem là chủ phương tiện.", a.limit = null, a.raw_text = "Trường hợp phương tiện do tổ chức, cá nhân có quyền sử dụng hợp pháp (theo hợp đồng thuê phương tiện bằng văn bản với tổ chức, cá nhân khác hoặc hợp đồng hợp tác kinh doanh theo quy định của pháp luật) trực tiếp đứng tên làm thủ tục đăng ký kinh doanh vận tải bằng xe ô tô cho phương tiện, kinh doanh dịch vụ cứu hộ giao thông đường bộ, cứu thương thì tổ chức, cá nhân đó là đối tượng để áp dụng xử phạt như chủ phương tiện;", a.applicable_articles = [];
MERGE (a:Authority {id: 'ND168_Art47_C7'}) SET a.title = "Quy định về việc kéo dài thời hạn ra quyết định xử phạt đối với chủ phương tiện để xác minh đối tượng bị xử phạt theo Luật Xử lý vi phạm hành chính.", a.limit = null, a.raw_text = "Khi xử phạt đối với chủ phương tiện quy định tại khoản 6 Điều này, thời hạn ra quyết định xử phạt có thể được kéo dài để xác minh đối tượng bị xử phạt theo quy định tại khoản 1 Điều 66 của Luật Xử lý vi phạm hành chính.", a.applicable_articles = [66];
MATCH (a:Authority {id: 'ND168_Art47_C7'}), (v:Violation) WHERE v.article IN a.applicable_articles AND (a.limit = 0 OR v.fine_max <= a.limit) MERGE (a)-[:CAN_SANCTION]->(v);
MERGE (a:Authority {id: 'ND168_Art47_C8'}) SET a.title = "Quy trình xử lý vi phạm hành chính khi được phát hiện qua phương tiện, thiết bị kỹ thuật nghiệp vụ mà chưa dừng ngay được phương tiện.", a.limit = null, a.raw_text = "Đối với trường hợp hành vi vi phạm hành chính được phát hiện thông qua sử dụng phương tiện, thiết bị kỹ thuật nghiệp vụ mà cơ quan chức năng chưa dừng ngay được phương tiện để xử lý thì thực hiện như sau:", a.applicable_articles = [];
MERGE (a:Authority {id: 'ND168_Art47_C8_pa'}) SET a.title = "Cơ quan chức năng gửi thông báo yêu cầu chủ phương tiện và các bên liên quan đến giải quyết vi phạm, có thể bằng văn bản hoặc điện tử, và cập nhật thông tin vi phạm trên trang thông tin điện tử của Cục Cảnh sát giao thông.", a.limit = null, a.raw_text = "Cơ quan chức năng gửi thông báo yêu cầu chủ phương tiện và cá nhân, tổ chức có liên quan (nếu có) đến trụ sở cơ quan, đơn vị của người có thẩm quyền xử phạt vi phạm hành chính để giải quyết vụ việc vi phạm. Việc thông báo được thực hiện bằng văn bản hoặc thực hiện thông báo bằng phương thức điện tử thông qua Ứng dụng giao thông trên thiết bị di động dành cho công dân (sau đây viết gọn là Ứng dụng giao thông trên thiết bị di động) do Bộ Công an xây dựng, quản lý, vận hành khi đáp ứng điều kiện về cơ sở hạ tầng, kỹ thuật, thông tin; đồng thời cập nhật thông tin về phương tiện vi phạm trên Trang thông tin điện tử của Cục Cảnh sát giao thông;", a.applicable_articles = [];
MERGE (a:Authority {id: 'ND168_Art47_C8_pb'}) SET a.title = "Chủ phương tiện có nghĩa vụ hợp tác xác định người điều khiển. Nếu cá nhân chủ phương tiện không hợp tác hoặc không chứng minh được mình không phải người vi phạm, sẽ bị xử phạt. Nếu tổ chức chủ phương tiện không hợp tác hoặc không giải trình được người điều khiển, sẽ bị xử phạt, trừ trường hợp phương tiện bị chiếm đoạt/sử dụng trái phép.", a.limit = null, a.raw_text = "Chủ phương tiện có nghĩa vụ phải hợp tác với cơ quan chức năng để xác định người đã điều khiển phương tiện thực hiện hành vi vi phạm.\nTrường hợp chủ phương tiện là cá nhân, nếu không hợp tác với cơ quan chức năng, không chứng minh hoặc không giải trình được mình không phải là người đã điều khiển phương tiện thực hiện hành vi vi phạm thì bị xử phạt đối với hành vi vi phạm được phát hiện;\nTrường hợp chủ phương tiện là tổ chức, nếu không hợp tác với cơ quan chức năng, không giải trình để xác định được người đã điều khiển phương tiện thực hiện hành vi vi phạm thì bị xử phạt vi phạm hành chính đối với tổ chức thực hiện hành vi vi phạm được phát hiện, trừ trường hợp phương tiện bị chiếm đoạt, sử dụng trái phép;", a.applicable_articles = [];
MERGE (a:Authority {id: 'ND168_Art47_C8_pc'}) SET a.title = "Việc chuyển kết quả thu thập được bằng phương tiện, thiết bị kỹ thuật nghiệp vụ đến người có thẩm quyền xử phạt để lập biên bản và ra quyết định xử phạt phải tuân theo quy định của Chính phủ.", a.limit = null, a.raw_text = "Việc chuyển kết quả thu thập được bằng phương tiện, thiết bị kỹ thuật nghiệp vụ đến người có thẩm quyền xử phạt vi phạm hành chính để lập biên bản vi phạm hành chính và ra quyết định xử phạt vi phạm hành chính thực hiện theo quy định của Chính phủ về danh mục, việc quản lý, sử dụng phương tiện, thiết bị kỹ thuật nghiệp vụ và quy trình thu thập, sử dụng dữ liệu thu được từ phương tiện, thiết bị kỹ thuật do cá nhân, tổ chức cung cấp để phát hiện vi phạm hành chính.", a.applicable_articles = [];
MERGE (a:Authority {id: 'ND168_Art47_C9'}) SET a.title = "Người có thẩm quyền xử phạt được sử dụng thông tin trong Cơ sở dữ liệu về trật tự, an toàn giao thông đường bộ, Luật Xử lý vi phạm hành chính, pháp luật về đo lường để xác định hành vi vi phạm.", a.limit = null, a.raw_text = "Người có thẩm quyền xử phạt được sử dụng các thông tin trong Cơ sở dữ liệu về trật tự, an toàn giao thông đường bộ theo quy định của Luật Trật tự, an toàn giao thông đường bộ, Luật Xử lý vi phạm hành chính, pháp luật về đo lường để làm căn cứ xác định hành vi vi phạm đối với cá nhân, tổ chức khi thực hiện một trong các hành vi vi phạm quy định tại Nghị định này.", a.applicable_articles = [];
MERGE (a:Authority {id: 'ND168_Art47_C10'}) SET a.title = "Quy định về việc xác minh để phát hiện hành vi vi phạm tại Điều 32 khoản 3 điểm a và khoản 7 điểm h, được thực hiện thông qua công tác điều tra tai nạn giao thông, đăng ký xe và xử lý vi phạm hành chính tại trụ sở đơn vị.", a.limit = null, a.raw_text = "Việc xác minh để phát hiện hành vi vi phạm quy định tại điểm a khoản 3, điểm h khoản 7 Điều 32 của Nghị định này được thực hiện thông qua công tác điều tra, giải quyết vụ tai nạn giao thông; qua công tác đăng ký xe; qua công tác xử lý vụ việc vi phạm hành chính tại trụ sở đơn vị.", a.applicable_articles = [32];
MATCH (a:Authority {id: 'ND168_Art47_C10'}), (v:Violation) WHERE v.article IN a.applicable_articles AND (a.limit = 0 OR v.fine_max <= a.limit) MERGE (a)-[:CAN_SANCTION]->(v);
MERGE (a:Authority {id: 'ND168_Art47_C11'}) SET a.title = "Trường hợp chủ phương tiện hoặc người vi phạm không giải quyết vụ việc hoặc không chấp hành quyết định xử phạt đúng thời hạn, người có thẩm quyền xử phạt sẽ gửi thông báo đến cơ quan đăng kiểm, đăng ký xe, cấp giấy phép lái xe.", a.limit = null, a.raw_text = "Trường hợp quá thời hạn hẹn đến giải quyết vụ việc vi phạm được ghi trong biên bản vi phạm hành chính hoặc trong thông báo của người có thẩm quyền xử phạt hoặc quá thời hạn thi hành quyết định xử phạt mà chủ phương tiện vi phạm, người vi phạm chưa thực hiện giải quyết vụ việc vi phạm theo quy định hoặc chưa chấp hành quyết định xử phạt thì người có thẩm quyền xử phạt gửi thông báo cho cơ quan đăng kiểm (đối với phương tiện có quy định phải kiểm định), cơ quan đăng ký xe, cơ quan cấp giấy phép lái xe (nếu đã xác định được người vi phạm). Việc gửi thông báo được thực hiện bằng văn bản hoặc thực hiện thông báo bằng phương thức điện tử thông qua kết nối, chia sẻ dữ liệu khi đáp ứng điều kiện về cơ sở hạ tầng, kỹ thuật, thông tin.", a.applicable_articles = [];
MERGE (a:Authority {id: 'ND168_Art47_C11_pa'}) SET a.title = "Cơ quan đăng kiểm, đăng ký xe, cấp giấy phép lái xe có trách nhiệm tra cứu dữ liệu vi phạm trước khi thực hiện các thủ tục đăng kiểm, đăng ký hoặc cấp/đổi/cấp lại giấy phép lái xe.", a.limit = null, a.raw_text = "Cơ quan đăng kiểm, cơ quan đăng ký xe, cơ quan cấp giấy phép lái xe trước khi thực hiện đăng kiểm, đăng ký xe, cấp, đổi, cấp lại giấy phép lái xe có trách nhiệm tra cứu dữ liệu phương tiện vi phạm, người vi phạm được cơ quan Cảnh sát giao thông gửi thông báo đến;", a.applicable_articles = [];
MERGE (a:Authority {id: 'ND168_Art47_C11_pb'}) SET a.title = "Nếu có thông tin về phương tiện/người vi phạm khi tra cứu dữ liệu, cơ quan liên quan sẽ chưa giải quyết việc đăng kiểm, đăng ký phương tiện hoặc cấp/đổi/cấp lại giấy phép lái xe.", a.limit = null, a.raw_text = "Trường hợp khi tra cứu dữ liệu theo quy định tại điểm a khoản này nếu có thông tin về phương tiện vi phạm, người vi phạm thì chưa giải quyết việc đăng kiểm, đăng ký phương tiện vi phạm, chưa cấp, đổi, cấp lại giấy phép lái xe đối với người vi phạm;", a.applicable_articles = [];
MERGE (a:Authority {id: 'ND168_Art47_C11_pc'}) SET a.title = "Sau khi chủ phương tiện/người vi phạm đã giải quyết vụ việc vi phạm, người có thẩm quyền xử phạt phải gửi thông báo ngay cho cơ quan đăng kiểm, đăng ký xe, cấp giấy phép lái xe để thực hiện các thủ tục liên quan.", a.limit = null, a.raw_text = "Sau khi chủ phương tiện, người vi phạm đã giải quyết vụ việc vi phạm theo quy định, người có thẩm quyền xử phạt phải gửi thông báo ngay cho cơ quan đăng kiểm, cơ quan đăng ký xe, cơ quan cấp giấy phép lái xe bằng văn bản hoặc theo hình thức kết nối, chia sẻ dữ liệu khi đáp ứng điều kiện về cơ sở hạ tầng, kỹ thuật, thông tin để thực hiện việc đăng kiểm, đăng ký xe, cấp, đổi, cấp lại giấy phép lái xe theo quy định.", a.applicable_articles = [];
MERGE (a:Authority {id: 'ND168_Art47_C12'}) SET a.title = "Quy định về việc gửi quyết định xử phạt, tạm giữ tang vật/phương tiện/giấy phép/chứng chỉ hành nghề và các biểu mẫu khác theo thủ tục hành chính, có thể gửi qua Cổng dịch vụ công, tài khoản định danh điện tử hoặc Ứng dụng giao thông trên thiết bị di động khi đáp ứng điều kiện kỹ thuật.", a.limit = null, a.raw_text = "Việc gửi quyết định xử phạt vi phạm hành chính, quyết định tạm giữ tang vật, phương tiện, giấy phép, chứng chỉ hành nghề theo thủ tục hành chính và các biểu mẫu khác trong xử phạt vi phạm hành chính thực hiện theo quy định của Luật Xử lý vi phạm hành chính và có thể gửi cho người vi phạm theo tài khoản đã đăng ký trên Cổng dịch vụ công Quốc gia, Cổng dịch vụ công Bộ Công an (sau đây viết gọn là Cổng dịch vụ công), tài khoản định danh điện tử trên ứng dụng định danh quốc gia, Ứng dụng giao thông trên thiết bị di động khi đáp ứng điều kiện về cơ sở hạ tầng, kỹ thuật, thông tin.", a.applicable_articles = [];
MERGE (a:Authority {id: 'ND168_Art48_C1'}) SET a.title = "Quy định về thẩm quyền tạm giữ phương tiện trước khi ra quyết định xử phạt để ngăn chặn ngay hành vi vi phạm hành chính, áp dụng cho các hành vi vi phạm được liệt kê cụ thể tại các điểm a đến o của khoản này.", a.limit = 0, a.raw_text = "Để ngăn chặn ngay hành vi vi phạm hành chính, người có thẩm quyền được phép tạm giữ phương tiện trước khi ra quyết định xử phạt theo quy định tại điểm b khoản 1, khoản 2, khoản 8 Điều 125 của Luật Xử lý vi phạm hành chính đối với những hành vi vi phạm được quy định tại các điều, khoản, điểm sau đây của Nghị định này:", a.applicable_articles = [125];
MATCH (a:Authority {id: 'ND168_Art48_C1'}), (v:Violation) WHERE v.article IN a.applicable_articles AND (a.limit = 0 OR v.fine_max <= a.limit) MERGE (a)-[:CAN_SANCTION]->(v);
MERGE (a:Authority {id: 'ND168_Art48_C1_pa'}) SET a.title = "Áp dụng tạm giữ phương tiện đối với các hành vi vi phạm tại Điều 6, cụ thể là điểm g khoản 5; điểm c khoản 6; điểm b khoản 7; điểm a khoản 9; điểm a, điểm b, điểm c, điểm d khoản 11; khoản 12; khoản 14.", a.limit = 0, a.raw_text = "Điểm g khoản 5; điểm c khoản 6; điểm b khoản 7; điểm a khoản 9; điểm a, điểm b, điểm c, điểm d khoản 11; khoản 12; khoản 14 Điều 6;", a.applicable_articles = [6];
