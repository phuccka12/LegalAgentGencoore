  {
    "node_id": "ND168_Art8_C4_d",
    "metadata": {
      "article": 8,
      "clause": 4,
      "point": "d"
    },
    "behavior": {
      "summary": "Quay đầu xe tại nơi giao nhau với đường sắt, nơi đường hẹp/dốc/cong bị che khuất, nơi có biển cấm quay đầu; rẽ trái/phải tại nơi có biển cấm rẽ trái/phải.",
      "raw_legal_text": "Quay đầu xe tại nơi đường bộ giao nhau cùng mức với đường sắt; quay đầu xe tại nơi đường hẹp, đường dốc, đoạn đường cong tầm nhìn bị che khuất, nơi có biển báo hiệu có nội dung cấm quay đầu đối với loại phương tiện đang điều khiển; điều khiển xe rẽ trái tại nơi có biển báo hiệu có nội dung cấm rẽ trái đối với loại phương tiện đang điều khiển; điều khiển xe rẽ phải tại nơi có biển báo hiệu có nội dung cấm rẽ phải đối với loại phương tiện đang điều khiển;",
      "semantic_expansion": {
