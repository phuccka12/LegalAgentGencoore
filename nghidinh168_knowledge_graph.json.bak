      "article": 21,
      "clause": 2,
      "point": "a"
    },
    "behavior": {
      "summary": "Chở hàng vượt trọng tải cho phép trên 10% đến 30% (hoặc 20% đến 30% đối với xe xi téc chở chất lỏng).",
      "raw_legal_text": "Điều khiển xe (kể cả rơ moóc và sơ mi rơ moóc) chở hàng vượt trọng tải (khối lượng hàng chuyên chở) cho phép tham gia giao thông được ghi trong giấy chứng nhận kiểm định an toàn kỹ thuật và bảo vệ môi trường của xe trên 10% đến 30% (trừ xe xi téc chở chất lỏng), trên 20% đến 30% đối với xe xi téc chở chất lỏng;",
      "semantic_expansion": {
        "synonyms": [],
        "slang": []
      }
    },
    "consequences": {
      "fine_range": {
