      "article": 8,
      "clause": 5,
      "point": "b"
    },
    "behavior": {
      "summary": "Không thực hiện biện pháp an toàn khi phương tiện hư hỏng tại nơi giao nhau với đường sắt.",
      "raw_legal_text": "Không thực hiện biện pháp bảo đảm an toàn theo quy định khi phương tiện bị hư hỏng trên đoạn đường bộ giao nhau cùng mức với đường sắt;",
