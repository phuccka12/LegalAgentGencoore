  {
    "node_id": "ND168_Art8_C2_a",
    "metadata": {
      "article": 8,
      "clause": 2,
      "point": "a"
    },
    "behavior": {
      "summary": "Dừng, đỗ xe sai quy định ở nhiều vị trí khác nhau như trên phần đường xe chạy ngoài đô thị, không sát mép đường, ngược chiều lưu thông, trên dải phân cách, không đúng vị trí quy định, trên dốc không chèn bánh, hoặc tại nơi có biển cấm.",
      "raw_legal_text": "Dừng xe, đỗ xe trên phần đường xe chạy ở đoạn đường ngoài đô thị nơi có lề đường rộng; dừng xe, đỗ xe không sát mép đường phía bên phải theo chiều đi ở nơi đường có lề đường hẹp hoặc không có lề đường; dừng xe, đỗ xe ngược với chiều lưu thông của làn đường; dừng xe, đỗ xe trên dải phân cách cố định ở giữa hai phần đường xe chạy; dừng xe, đỗ xe không đúng vị trí quy định ở những đoạn đường đã có bố trí nơi dừng xe, đỗ xe; đỗ xe trên dốc không chèn bánh; dừng xe nơi có biển “Cấm dừng xe và đỗ xe”; đỗ xe nơi có biển “Cấm đỗ xe” hoặc biển “Cấm dừng xe và đỗ xe”, trừ hành vi vi phạm quy định tại điểm b khoản 6 Điều này;",
      "semantic_expansion": {
        "synonyms": [],
        "slang": []
      }
    },
    "consequences": {
      "fine_range": {
        "min": 600000,
        "max": 800000,
        "suggested": 700000
      },
      "point_deduction": 0,
      "remedial_measures": []
    },
    "legal_procedure": {
      "evidence_requirements": {
        "mandatory": [],
