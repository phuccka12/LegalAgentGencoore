    "metadata": {
      "article": 8,
      "clause": 4,
      "point": "e"
    },
    "behavior": {
      "summary": "Lùi xe ở đường một chiều, đường cấm đi ngược chiều, khu vực cấm dừng, trên phần đường người đi bộ, nơi giao nhau, giao với đường sắt, nơi tầm nhìn bị che khuất; lùi xe không quan sát hoặc không có tín hiệu.",
      "raw_legal_text": "Lùi xe ở đường một chiều, đường có biển “Cấm đi ngược chiều”, khu vực cấm dừng, trên phần đường dành cho người đi bộ qua đường, nơi đường bộ giao nhau, đường bộ giao nhau cùng mức với đường sắt, nơi tầm nhìn bị che khuất; lùi xe không quan sát hai bên và phía sau xe hoặc không có tín hiệu lùi xe.",
      "semantic_expansion": {
        "synonyms": [],
