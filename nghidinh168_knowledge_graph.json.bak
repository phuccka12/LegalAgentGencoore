  {
    "node_id": "ND168_Art8_C4_c",
    "metadata": {
      "article": 8,
      "clause": 4,
      "point": "c"
    },
    "behavior": {
      "summary": "Không tuân thủ quy định về dừng, đỗ xe tại nơi giao nhau với đường sắt hoặc trong phạm vi bảo vệ/an toàn của đường sắt.",
      "raw_legal_text": "Không tuân thủ các quy định về dừng xe, đỗ xe tại nơi đường bộ giao nhau cùng mức với đường sắt; dừng xe, đỗ xe trong phạm vi bảo vệ công trình đường sắt, phạm vi an toàn của đường sắt;",
      "semantic_expansion": {
        "synonyms": [],
        "slang": []
      }
    },
    "consequences": {
      "fine_range": {
        "min": 1000000,
        "max": 2000000,
